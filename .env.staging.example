# ============================================================================
# ERP/POS — Staging/UAT Environment
# ----------------------------------------------------------------------------
# This file is the single source of truth for staging/UAT configuration.
# Copy to .env when running against staging:  cp .env.staging .env
#
# SECURITY:
#   - All keys here are SANDBOX / UAT credentials only. Do NOT use in prod.
#   - Replace placeholder values with real sandbox credentials from each
#     provider's developer portal before running UAT.
#   - Never commit production secrets. Use a secrets manager for prod.
#
# Generated: 2026-07-15 (REDTEAM go-live prep)
# ============================================================================

# ── Database (PostgreSQL 16+ staging instance) ─────────────────────────────
# Using the local PostgreSQL 17.10 socket-bound instance on port 5433.
# In real staging, replace with: postgresql://erp_app:****@staging-db.internal:5432/erp_pos_staging?schema=public
DATABASE_URL="postgresql://erp_app:CHANGE_ME_STAGING_DB_PASSWORD@localhost:5433/erp_pos_staging?schema=public"

# ── Application ────────────────────────────────────────────────────────────
NODE_ENV="staging"
APP_VERSION="4.1.0-staging"
DEPLOY_REGION="bd-dhk-1"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
HOSTNAME="0.0.0.0"
PORT="3000"

# ── Secrets (staging-only values; rotate before prod) ──────────────────────
# Generate with: openssl rand -base64 48
JWT_SECRET="GENERATE_WITH_OPENSSL_RAND_BASE64_48"
# Generate with: openssl rand -base64 32
APP_ENCRYPTION_KEY="GENERATE_WITH_OPENSSL_RAND_BASE64_32"
# Generate with: openssl rand -hex 32
BARCODE_SIGNING_KEY="GENERATE_WITH_OPENSSL_RAND_HEX_32"

# ── Redis (BullMQ workers + rate limits + cache) ───────────────────────────
# In staging: redis://staging-redis.internal:6379
REDIS_URL="redis://localhost:6379"

# ── Provider Mode ──────────────────────────────────────────────────────────
# mock  = all providers return success without making real API calls (dev)
# sandbox = use real provider sandbox/test endpoints (UAT)
# live  = real production endpoints (prod only — never set in .env.staging)
PROVIDER_MODE="sandbox"

# ── bKash Payment Gateway (sandbox) ────────────────────────────────────────
# Apply at: https://developer.bka.sh/api-info/Direct-API
BKASH_API_URL="https://tokenized.sandbox.bka.sh/v1.2.0-beta"
BKASH_USERNAME="sandbox-bkash-username"
BKASH_PASSWORD="sandbox-bkash-password"
BKASH_APP_KEY="sandbox-bkash-app-key"
BKASH_APP_SECRET="sandbox-bkash-app-secret"

# ── Nagad Payment Gateway (sandbox) ────────────────────────────────────────
# Apply at: https://developer.nagad.com.bd/
NAGAD_API_URL="https://sandbox-ssl.mynagad.com/api/dfs"
# NAGAD_MERCHANT_ID, NAGAD_PUBLIC_KEY, NAGAD_PRIVATE_KEY are loaded from
# files referenced via NAGAD_PUBLIC_KEY_PATH / NAGAD_PRIVATE_KEY_PATH in prod.
# Sandbox uses a fixed keypair provided by Nagad developer support.

# ── SSL Wireless SMS (sandbox) ─────────────────────────────────────────────
# Apply at: https://sms.sslwireless.com/
SSL_SMS_API_URL="https://sms.sslwireless.com/pushapi/dynamic/server.php"
SSL_SMS_API_KEY="sandbox-ssl-sms-api-key"
SSL_SMS_API_PASS="sandbox-ssl-sms-api-pass"
SSL_SMS_SENDER_ID="DemoOTP"

# ── Mim SMS (sandbox) ──────────────────────────────────────────────────────
# Apply at: https://mimsms.com/
MIM_SMS_API_URL="https://api.mimsms.com/api/SmsSending/SMS"
MIM_SMS_API_KEY="sandbox-mim-sms-api-key"

# ── SendGrid Email (sandbox) ───────────────────────────────────────────────
# Apply at: https://app.sendgrid.com/settings/api_keys
SENDGRID_API_KEY="SG.sandbox-replace-with-real-sendgrid-key"
SENDGRID_FROM_EMAIL="staging-no-reply@example.com"

# ── AWS SES Email (sandbox) ────────────────────────────────────────────────
# SES sandbox mode only sends to verified addresses
SES_REGION="ap-south-1"

# ── Resend Email (sandbox) ─────────────────────────────────────────────────
# Apply at: https://resend.com/api-keys
RESEND_API_KEY="re_sandbox-replace-with-real-resend-key"
RESEND_FROM_EMAIL="staging-no-reply@resend.dev"

# ── Pathao Courier (sandbox) ───────────────────────────────────────────────
# Apply at: https://merchant.pathao.com/developer
PATHAO_API_URL="https://courier-api-sandbox.pathao.com"
PATHAO_API_KEY="sandbox-pathao-api-key"
PATHAO_SECRET_KEY="sandbox-pathao-secret-key"
PATHAO_STORE_ID="1"

# ── RedX Courier (sandbox) ─────────────────────────────────────────────────
# Apply at: https://redx.com.bd/business-api
REDX_API_URL="https://sandbox.redx.com.bd/v1"
REDX_API_KEY="sandbox-redx-api-key"

# ── Webhook Auth Tokens (staging) ──────────────────────────────────────────
# Used by /api/v1/webhooks/courier/[provider] to verify X-Courier-Token header
COURIER_WEBHOOK_TOKEN="GENERATE_STRONG_RANDOM_TOKEN"

# ── Cron Job Auth (staging) ────────────────────────────────────────────────
# Used by /api/v1/cron/* endpoints to verify Authorization: Bearer ${CRON_API_TOKEN}
CRON_API_TOKEN="GENERATE_STRONG_RANDOM_TOKEN"

# ── Risk Alerting (FP/FN monitoring) ───────────────────────────────────────
RISK_ALERT_WINDOW_DAYS="30"
RISK_ALERT_PRECISION_THRESHOLD="0.40"
RISK_ALERT_RECALL_THRESHOLD="0.85"
RISK_ALERT_FP_COUNT_THRESHOLD="5"
RISK_ALERT_FN_LOSS_THRESHOLD="50000"
RISK_ALERT_RECIPIENT_EMAIL="risk-staging@example.com"

# ── Notification Channels (staging) ────────────────────────────────────────
# Replace with real staging Slack/Telegram channels for alert testing.
# NOTE: Do NOT put a real Slack webhook URL here — GitHub's secret scanner
# will block the push. Use the placeholder below and replace it in your
# local .env.staging file (which is gitignored).
SLACK_WEBHOOK_URL="REPLACE_WITH_YOUR_SLACK_WEBHOOK_URL_LOCAL_ONLY"
SLACK_CHANNEL="#erp-staging-alerts"
TELEGRAM_BOT_TOKEN="REPLACE_WITH_YOUR_TELEGRAM_BOT_TOKEN_LOCAL_ONLY"
TELEGRAM_CHAT_ID="-0000000000000"

# ── Mock Provider Tuning (used when PROVIDER_MODE=mock) ────────────────────
MOCK_SMS_FAILURE_RATE="0.0"
MOCK_VERBOSE="true"

# ── Worker Concurrency ─────────────────────────────────────────────────────
WORKER_CONCURRENCY="2"

# ── Business Rule Tunables ─────────────────────────────────────────────────
RESERVATION_TTL_MINUTES="15"
AUDIT_RETENTION_DAYS="2555"
CUSTOMER_ANONYMIZE_DAYS="1095"

# ── WebAuthn / Passkeys (staging) ──────────────────────────────────────────
WEBAUTHN_RP_ID="localhost"
WEBAUTHN_ORIGIN="http://localhost:3000"

# ── Sentry (staging) ───────────────────────────────────────────────────────
SENTRY_DSN=""
OTEL_SERVICE_NAME="erp-pos-staging"

# ── Feature Flags (all enabled for UAT) ────────────────────────────────────
FEATURE_CREDIT_SALES="true"
FEATURE_OFFLINE_POS="true"
FEATURE_ASSET_MANAGEMENT="true"
FEATURE_BANK_RECONCILIATION="true"
FEATURE_MULTI_CURRENCY="true"
FEATURE_PAYROLL="true"
FEATURE_CRM="true"
FEATURE_DELIVERY="true"
FEATURE_SERVICE_WARRANTY="true"
FEATURE_IMPORTS="true"
FEATURE_LOYALTY="true"
FEATURE_HR="true"
