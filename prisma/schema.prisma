  code                String
  withholdingType     String   @default("TDS") @map("withholding_type") // TDS/VDS/OTHER
  appliesTo           String   @default("supplier_payment") @map("applies_to") // supplier_payment/customer_payment/expense
  rate                Decimal  @default(0)
  minimumBaseAmount   Decimal  @default(0) @map("minimum_base_amount")
  effectiveFrom       DateTime @map("effective_from")
  effectiveTo         DateTime? @map("effective_to")
  conditions          String   @default("{}") // JSONB
  isActive            Boolean  @default(true) @map("is_active")

