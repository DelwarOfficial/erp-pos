// ERP/POS Multi-tenant System — Phase M0 Schema
// Mirrors §5.1, §5.2, §5.3, §5.15 of ERP_Product_Blueprint_v4.1.md
// NOTE: Sandbox uses SQLite. RLS is enforced in the application layer via
// the request-scoped transaction wrapper (src/lib/db/transaction.ts) and
// the Prisma client extension that injects company_id filters. See
// docs/adr/0002-rls-via-middleware.md for the full rationale.

generator client {
  provider = "prisma-client-js"
  preview = ["postgresqlExtensions"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ──────────────────────────────────────────────────────────────────────
// §5.1 Organization and Currency
// ──────────────────────────────────────────────────────────────────────

model Currency {
  code           String   @id
  name           String  
  decimalPlaces  Int      @default(2) @map("decimal_places")
  isActive       Boolean  @default(true) @map("is_active")

  exchangeRates       ExchangeRate[]
  baseForCompanies    Company[]              @relation("BaseCurrency")
  lockedOnDocuments   DocumentExchangeRate[]
  productPrices       ProductPrice[]
  // M2 backward relations
  suppliers           Supplier[]
  purchases           Purchase[]
  landedCostDocuments LandedCostDocument[]
  // M3 backward relations
  quotations          Quotation[]
  sales               Sale[]
  payments            Payment[]
  // M4 early — financial accounts
  financialAccounts   FinancialAccount[]
  // M4 — accounting
  journalEntries      JournalEntry[]   @relation("JournalEntryCurrency")
  journalLines        JournalLine[]    @relation("JournalLineCurrency")
  expenses            Expense[]        @relation("ExpenseCurrency")
  // Gap model backward relations
  accountTransfersFrom AccountTransfer[] @relation("TransferFromCurrency")
  accountTransfersTo   AccountTransfer[] @relation("TransferToCurrency")

  @@map("currencies")
}

model Company {
  id                  String   @id @default(uuid())
  legalName           String   @map("legal_name")
  displayName         String   @map("display_name")
  code                String   @unique
  baseCurrencyCode    String   @map("base_currency_code")
  timezone            String   @default("Asia/Dhaka")
  countryCode         String   @default("BD") @map("country_code")
  bin                 String?  @unique
  tin                 String?  @unique
  vatRegistered       Boolean  @default(false) @map("vat_registered")
  status              String   @default("active") // active/suspended/closed
  defaultLocale       String   @default("bn-BD") @map("default_locale")
  dateFormat          String   @default("dd MMM yyyy") @map("date_format")
  fiscalYearStartMonth Int     @default(7) @map("fiscal_year_start_month")
  createdAt           DateTime @default(now()) @map("created_at")

  baseCurrency        Currency        @relation("BaseCurrency", fields: [baseCurrencyCode], references: [code])
  branches            Branch[]
  warehouses          Warehouse[]
  users               User[]
  roles               Role[]
  devices             Device[]
  exchangeRates       ExchangeRate[]
  companyDomains      CompanyDomain[]
  documentSequences   DocumentSequence[]
  documentNumberLeases DocumentNumberLease[]
  idempotencyRequests IdempotencyRequest[]
  businessEvents      BusinessEvent[]
  auditLogs           AuditLog[]
  approvalRequests    ApprovalRequest[]
  statutoryDocuments  StatutoryDocument[]
  taxReturnPeriods    TaxReturnPeriod[]
  reconciliationRuns  ReconciliationRun[]
  reconciliationFindings ReconciliationFinding[]
  recoveryEpochs      RecoveryEpoch[]
  refreshTokens       RefreshToken[]
  securityEvents      SecurityEvent[]
  integrationCredentials IntegrationCredential[]
  // M1 backward relations
  categories          Category[]
  brands              Brand[]
  units               Unit[]
  customerGroups      CustomerGroup[]
  products            Product[]
  mediaAssets         MediaAsset[]
  entityMediaLinks    EntityMediaLink[]
  productBarcodes     ProductBarcode[]
  discountPolicies    DiscountPolicy[]
  productPrices       ProductPrice[]
  taxCodes            TaxCode[]
  taxComponents       TaxComponent[]
  withholdingRules    WithholdingRule[]
  productComboItems   ProductComboItem[]
  productUnitOptions  ProductUnitOption[]
  configurationValues ConfigurationValue[]
  posProfiles         PosProfile[]
  documentTemplates   DocumentTemplate[]
  companyLanguages    CompanyLanguage[]
  translationOverrides TranslationOverride[]
  featureFlags        FeatureFlag[]
  dashboardPreferences DashboardPreference[]
  salesTargets        SalesTarget[]
  savedReportFilters  SavedReportFilter[]
  reportExportJobs    ReportExportJob[]
  supportTickets      SupportTicket[]
  supportTicketMessages SupportTicketMessage[]
  communicationTemplates CommunicationTemplate[]
  // Step 3 — WebAuthn
  webauthnCredentials WebAuthnCredential[]
  webauthnChallenges  WebAuthnChallenge[]
  // M2 backward relations
  warehouseStocks     WarehouseStock[]
  stockMovements      StockMovement[]
  stockReservations   StockReservation[]
  productBatches      ProductBatch[]
  stockMovementBatches StockMovementBatch[]
  productSerials      ProductSerial[]
  serialEvents        SerialEvent[]
  inventoryReasonCodes InventoryReasonCode[]
  stockCounts         StockCount[]
  stockAdjustments    StockAdjustment[]
  stockAdjustmentItems StockAdjustmentItem[]
  customers           Customer[]
  suppliers           Supplier[]
  purchases           Purchase[]
  purchaseItems       PurchaseItem[]
  purchaseItemTaxes   PurchaseItemTax[]
  purchaseReceivings  PurchaseReceiving[]
  purchaseReceivingItems PurchaseReceivingItem[]
  landedCostDocuments LandedCostDocument[]
  purchaseReturns     PurchaseReturn[]
  purchaseReturnItems PurchaseReturnItem[]
  transfers           Transfer[]
  transferItems       TransferItem[]
  // M2 — junction-table backward relations (have companyId column)
  stockCountItems     StockCountItem[]
  stockCountSerials   StockCountSerial[]
  // M3 backward relations
  quotations          Quotation[]
  quotationItems      QuotationItem[]
  sales               Sale[]
  saleItems           SaleItem[]
  saleItemTaxes       SaleItemTax[]
  saleReturns         SaleReturn[]
  saleReturnItems     SaleReturnItem[]
  cashierShifts       CashierShift[]
  cashDrawerCounts    CashDrawerCount[]
  payments            Payment[]
  paymentAllocations  PaymentAllocation[]
  returnRefundAllocations ReturnRefundAllocation[]
  installments        Installment[]
  installmentAllocations InstallmentAllocation[]
  // M4 early — financial accounts
  chartOfAccounts     ChartOfAccount[]
  financialAccounts   FinancialAccount[]
  // M4 — accounting
  fiscalPeriods       FiscalPeriod[]
  journalEntries      JournalEntry[]
  journalLines        JournalLine[]
  accountingPolicies  AccountingPolicy[]
  expenseCategories   ExpenseCategory[]
  expenses            Expense[]
  expenseItems        ExpenseItem[]
  // M5 — delivery + service
  deliveryOrders      DeliveryOrder[]
  deliveryItems       DeliveryItem[]
  deliveryEvents      DeliveryEvent[]
  courierShipments    CourierShipment[]
  courierCodSettlements CourierCodSettlement[]
  serviceRequests     ServiceRequest[]
  serviceRequestParts ServiceRequestPart[]
  serviceEvents       ServiceEvent[]
  warrantyClaims      WarrantyClaim[]
  // M6 — CRM + HR + gift cards + notifications
  leadSubjects        LeadSubject[]
  leadSources         LeadSource[]
  leadStatuses        LeadStatus[]
  leads               Lead[]
  leadActivities      LeadActivity[]
  giftCards           GiftCard[]
  departments         Department[]
  designations        Designation[]
  employees           Employee[]
  payrollRuns         PayrollRun[]
  notifications       Notification[]
  // M7 — integrations + offline
  outboxEvents        OutboxEvent[]
  webhookEndpoints    WebhookEndpoint[]
  webhookDeliveries   WebhookDelivery[]
  importJobs          ImportJob[]
  importJobErrors     ImportJobError[]
  offlineCommands     OfflineCommand[]
  offlineSyncBatches  OfflineSyncBatch[]
  // Gap models
  accountTransfers      AccountTransfer[]
  dataSubjectRequests   DataSubjectRequest[]
  legalHolds           LegalHold[]
  printJobs            PrintJob[]
  riskAssessments      RiskAssessment[]
  riskAssessmentOutcomes RiskAssessmentOutcome[]
  currencyRevaluations CurrencyRevaluation[]
  stockBudgetLeases    StockBudgetLease[]
  holidays             Holiday[]
  leaveTypes           LeaveType[]
  leaveRequests        LeaveRequest[]
  payrollComponents    PayrollComponent[]
  payrollItems         PayrollItem[]
  customerAdvanceLedger CustomerAdvanceLedger[]
  supplierAdvanceLedger SupplierAdvanceLedger[]
  withholdingTransactionsGeneral WithholdingTransaction[]
  communicationConsents CommunicationConsent[]
  communicationCampaigns CommunicationCampaign[]
  communicationCampaignRecipients CommunicationCampaignRecipient[]
  outboundMessages     OutboundMessage[]
  coupons              Coupon[]
  rewardPointTransactions RewardPointTransaction[]
  expenseItemTaxes     ExpenseItemTax[]
  expenseAttachments   ExpenseAttachment[]
  giftCardTransactions GiftCardTransaction[]
  couponRedemptions   CouponRedemption[]
  rewardPointConsumptions RewardPointConsumption[]
  payrollItemComponents PayrollItemComponent[]
  attendanceRecords   AttendanceRecord[]
  // AM-BR — Fixed asset + bank reconciliation
  fixedAssets             FixedAsset[]
  fixedAssetCategories    FixedAssetCategory[]
  fixedAssetDepreciations FixedAssetDepreciation[]
  bankReconciliations     BankReconciliation[]
  bankReconciliationLines BankReconciliationLine[]

  @@index([status])
  @@map("companies")
}

model Branch {
  id          String   @id @default(uuid())
  companyId   String   @map("company_id")
  name        String  
  code        String  
  phone       String? 
  email       String? 
  address     String?
  binOverride String?  @map("bin_override")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")

  company          Company       @relation(fields: [companyId], references: [id], onDelete: Restrict)
  warehouses       Warehouse[]
  usersPrimary     User[]        @relation("PrimaryBranch")
  userBranchAccess UserBranchAccess[]
  devices          Device[]
  documentSequences DocumentSequence[]
  documentNumberLeases DocumentNumberLease[]
  approvalRequests ApprovalRequest[]
  statutoryDocuments StatutoryDocument[]
  reconciliationFindings ReconciliationFinding[]
  // M1 backward relations
  discountPolicies  DiscountPolicy[]     @relation("DiscountPolicyBranch")
  productPrices     ProductPrice[]       @relation("ProductPriceBranch")
  posProfiles       PosProfile[]
  salesTargets      SalesTarget[]       @relation("SalesTargetBranch")
  // M2 backward relations
  stockCounts       StockCount[]
  stockAdjustments  StockAdjustment[]
  purchases         Purchase[]
  purchaseReceivings PurchaseReceiving[]
  purchaseReturns   PurchaseReturn[]
  customerPreferred Customer[]          @relation("CustomerPreferredBranch")
  // M3 backward relations
  quotations       Quotation[]
  sales            Sale[]
  saleReturns      SaleReturn[]
  cashierShifts    CashierShift[]
  payments         Payment[]
  // M4 early — financial accounts (branch-scoped)
  financialAccounts FinancialAccount[]
  // M4 — accounting
  journalLines   JournalLine[]        @relation("JournalLineBranch")
  expenses       Expense[]            @relation("ExpenseBranch")
  // M5 — delivery + service
  deliveryOrders DeliveryOrder[]
  courierCodSettlements CourierCodSettlement[]
  // M5 — service
  serviceRequests ServiceRequest[]
  // M6 — CRM + HR
  leads           Lead[]              @relation("LeadBranch")
  employees       Employee[]          @relation("EmployeeBranch")
  payrollRuns     PayrollRun[]        @relation("PayrollRunBranch")
  // Gap model backward relations
  holidays             Holiday[]           @relation("HolidayBranch")
  stockBudgetLeases    StockBudgetLease[]  @relation("StockBudgetBranch")
  accountTransfers     AccountTransfer[]
  // AM-BR — fixed assets
  fixedAssets          FixedAsset[]

  @@unique([companyId, code])
  @@index([companyId, isActive])
  @@map("branches")
}

model Warehouse {
  id            String   @id @default(uuid())
  companyId     String   @map("company_id")
  branchId      String   @map("branch_id")
  name          String  
  code          String  
  warehouseType String   @default("retail") @map("warehouse_type") // retail/central/repair/damaged/transit
  isActive      Boolean  @default(true) @map("is_active")

  company Company @relation(fields: [companyId], references: [id], onDelete: Restrict)
  branch  Branch  @relation(fields: [branchId], references: [id])
  posProfiles PosProfile[]
  // M2 backward relations
  warehouseStocks    WarehouseStock[]
  stockMovements     StockMovement[]
  stockReservations  StockReservation[]
  productBatches     ProductBatch[]
  productSerialsCurrent ProductSerial[]
  serialEventsFrom   SerialEvent[]         @relation("SerialEventFromWh")
  serialEventsTo     SerialEvent[]         @relation("SerialEventToWh")
  stockCounts        StockCount[]
  stockAdjustments   StockAdjustment[]
  purchases          Purchase[]
  purchaseReceivings PurchaseReceiving[]
  purchaseReturns    PurchaseReturn[]
  transfersFrom      Transfer[]            @relation("TransferFromWh")
  transfersTo        Transfer[]            @relation("TransferToWh")
  // M3 backward relations
  sales              Sale[]
  saleReturns        SaleReturn[]
  cashierShifts      CashierShift[]
  // M5 — repair warehouse for service requests
  serviceRequestsRepair ServiceRequest[]
  // Gap model backward relations
  stockBudgetLeases StockBudgetLease[] @relation("StockBudgetWarehouse")

  @@unique([companyId, code])
  @@unique([companyId, branchId, name])
  @@index([companyId])
  @@index([branchId])
  @@index([warehouseType])
  @@map("warehouses")
}

model ExchangeRate {
  id            String   @id @default(uuid())
  companyId     String   @map("company_id")
  currencyCode  String   @map("currency_code")
  rateDate      DateTime @map("rate_date")
  rateToBase    Decimal  @map("rate_to_base")
  source        String  
  approvedBy    String?  @map("approved_by")
  createdAt     DateTime @default(now()) @map("created_at")

  company       Company  @relation(fields: [companyId], references: [id], onDelete: Restrict)
  currency      Currency @relation(fields: [currencyCode], references: [code])
  approver      User?    @relation(fields: [approvedBy], references: [id])

  @@unique([companyId, currencyCode, rateDate])
  @@index([companyId])
  @@index([currencyCode])
  @@map("exchange_rates")
}

model CompanyDomain {
  id                   String   @id @default(uuid())
  companyId            String   @map("company_id")
  hostname             String   @unique
  domainType           String   @default("platform_subdomain") @map("domain_type") // platform_subdomain/custom
  verificationTokenHash String? @map("verification_token_hash")
  verifiedAt           DateTime? @map("verified_at")
  tlsStatus            String   @default("pending") @map("tls_status") // pending/active/error
  isPrimary            Boolean  @default(false) @map("is_primary")
  createdAt            DateTime @default(now()) @map("created_at")

  company Company @relation(fields: [companyId], references: [id], onDelete: Restrict)

  @@index([companyId])
  @@index([domainType])
  @@index([tlsStatus])
  @@index([isPrimary])
  @@map("company_domains")
}

// ──────────────────────────────────────────────────────────────────────
// §5.2 Identity, RBAC, and Devices
// ──────────────────────────────────────────────────────────────────────

model User {
  id                  String   @id @default(uuid())
  companyId           String   @map("company_id")
  name                String  
  email               String  
  phone               String? 
  passwordHash        String   @map("password_hash")
  primaryBranchId     String?  @map("primary_branch_id")
  accessScope         String   @default("single_branch") @map("access_scope") // single_branch/multi_branch/global
  isActive            Boolean  @default(true) @map("is_active")
  mfaEnabled          Boolean  @default(false) @map("mfa_enabled")
  mfaSecretCiphertext Bytes?   @map("mfa_secret_ciphertext") // SQLite: BLOB
  failedLoginCount    Int      @default(0) @map("failed_login_count")
  lockedUntil         DateTime? @map("locked_until")
  passwordChangedAt   DateTime @default(now()) @map("password_changed_at")
  lastLoginAt         DateTime? @map("last_login_at")
  lastLoginIp         String?  @map("last_login_ip")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @default(now()) @map("updated_at")
  deletedAt           DateTime? @map("deleted_at")

  company             Company            @relation(fields: [companyId], references: [id], onDelete: Restrict)
  primaryBranch       Branch?            @relation("PrimaryBranch", fields: [primaryBranchId], references: [id])
  roles               UserRole[]
  branchAccess        UserBranchAccess[]
  devicesRegistered   Device[]           @relation("DeviceRegistrant")
  refreshTokens       RefreshToken[]
  securityEvents      SecurityEvent[]
  auditLogs           AuditLog[]
  approvalsRequested  ApprovalRequest[]  @relation("ApprovalRequestedBy")
  approvalsApproved   ApprovalRequest[]  @relation("ApprovalApprovedBy")
  approvalsWaived     ApprovalRequest[]  @relation("ApprovalWaivedBy")
  reconciliationInitiated ReconciliationRun[]
  reconciliationResolved ReconciliationFinding[]
  exchangeRatesApproved ExchangeRate[]
  statutoryIssued     StatutoryDocument[]
  integrationCreated  IntegrationCredential[]
  // M1 backward relations
  mediaCreated        MediaAsset[]         @relation("MediaCreatedBy")
  configUpdated       ConfigurationValue[] @relation("ConfigUpdatedBy")
  templateApproved    DocumentTemplate[]   @relation("TemplateApprovedBy")
  translationUpdated  TranslationOverride[] @relation("TranslationUpdatedBy")
  featureFlagUpdated  FeatureFlag[]        @relation("FeatureFlagUpdatedBy")
  salesTargetUser     SalesTarget[]        @relation("SalesTargetUser")
  salesTargetCreator  SalesTarget[]        @relation("SalesTargetCreator")
  savedReportFilters  SavedReportFilter[]  @relation("SavedReportFilterUser")
  reportExportRequests ReportExportJob[]   @relation("ReportExportRequester")
  supportTicketOpened SupportTicket[]      @relation("SupportTicketOpener")
  supportTicketAssigned SupportTicket[]    @relation("SupportTicketAssignee")
  supportTicketAuthored SupportTicketMessage[] @relation("SupportTicketAuthor")
  commTemplateApproved CommunicationTemplate[] @relation("CommTemplateApprovedBy")
  dashboardPreference DashboardPreference?
  // Step 3 — WebAuthn
  webauthnCredentials WebAuthnCredential[]
  webauthnChallenges  WebAuthnChallenge[] @relation("WebAuthnChallengeUser")
  // M3 backward relations
  salesBilled         Sale[]                @relation("SaleBiller")
  salesVoided         Sale[]                @relation("SaleVoidedBy")
  cashierShiftsCashier CashierShift[]       @relation("CashierShiftCashier")
  cashierShiftsApprover CashierShift[]      @relation("CashierShiftApprover")
  cashDrawerCounts    CashDrawerCount[]     @relation("CashDrawerCountBy")
  paymentsCreated     Payment[]             @relation("PaymentCreatedBy")
  paymentAllocationsCreated PaymentAllocation[] @relation("PaymentAllocCreatedBy")
  saleReturnsApproved SaleReturn[]          @relation("SaleReturnApprovedBy")
  saleReturnsCreated  SaleReturn[]          @relation("SaleReturnCreatedBy")
  // M4 — accounting
  fiscalPeriodsLocked FiscalPeriod[]        @relation("FiscalPeriodLockedBy")
  journalEntriesCreated JournalEntry[]      @relation("JournalEntryCreatedBy")
  journalEntriesPosted  JournalEntry[]      @relation("JournalEntryPostedBy")
  expensesRequested   Expense[]             @relation("ExpenseRequestedBy")
  expensesApproved    Expense[]             @relation("ExpenseApprovedBy")
  // M5 — delivery + service
  deliveriesAssigned  DeliveryOrder[]       @relation("DeliveryAssignedTo")
  deliveriesCreated   DeliveryOrder[]       @relation("DeliveryCreatedBy")
  deliveryEventsCreated DeliveryEvent[]     @relation("DeliveryEventCreatedBy")
  codSettlementsCreated CourierCodSettlement[] @relation("CodSettlementCreatedBy")
  serviceRequestsCreated ServiceRequest[]   @relation("ServiceRequestCreatedBy")
  serviceEventsCreated ServiceEvent[]       @relation("ServiceEventCreatedBy")
  warrantyClaimsApproved WarrantyClaim[]    @relation("WarrantyClaimApprovedBy")
  // M6 — CRM + HR + gift cards + notifications
  leadsAssigned     Lead[]               @relation("LeadAssignedTo")
  leadsCreated      Lead[]               @relation("LeadCreatedBy")
  leadActivitiesCreated LeadActivity[]   @relation("LeadActivityCreatedBy")
  giftCardsIssued   GiftCard[]           @relation("GiftCardIssuedBy")
  employee          Employee?            @relation("EmployeeUser")
  payrollRunsApproved PayrollRun[]       @relation("PayrollRunApprovedBy")
  payrollRunsCreated  PayrollRun[]       @relation("PayrollRunCreatedBy")
  // Gap model backward relations
  expenseAttachmentsUploaded ExpenseAttachment[] @relation("ExpenseAttachmentUploadedBy")
  customerAdvanceLedgerCreated CustomerAdvanceLedger[]
  supplierAdvanceLedgerCreated SupplierAdvanceLedger[]
  accountTransfersCreated AccountTransfer[] @relation("TransferCreatedBy")
  accountTransfersApproved AccountTransfer[] @relation("TransferApprovedBy")
  campaignsCreated    CommunicationCampaign[] @relation("CampaignCreatedBy")
  campaignsApproved   CommunicationCampaign[] @relation("CampaignApprovedBy")
  userNotifications   UserNotification[]  @relation("UserNotificationUser")
  legalHoldsDeclared  LegalHold[]         @relation("LegalHoldDeclaredBy")
  printJobsRequested  PrintJob[]          @relation("PrintJobRequestedBy")

  @@unique([companyId, email])
  @@index([companyId])
  @@index([phone])
  @@index([primaryBranchId])
  @@index([accessScope])
  @@index([isActive])
  @@index([lockedUntil])
  @@index([deletedAt])
  @@map("users")
}

model Role {
  id          String   @id @default(uuid())
  companyId   String   @map("company_id")
  name        String  
  description String? 
  isSystemRole Boolean @default(false) @map("is_system_role")
  createdAt   DateTime @default(now()) @map("created_at")

  company     Company         @relation(fields: [companyId], references: [id], onDelete: Restrict)
  permissions RolePermission[]
  users       UserRole[]

  @@unique([companyId, name])
  @@index([companyId])
  @@map("roles")
}

model Permission {
  id          String   @id @default(uuid())
  code        String   @unique // resource.action.scope
  module      String  
  description String  

  roles       RolePermission[]

  @@index([module])
  @@map("permissions")
}

model RolePermission {
  roleId       String @map("role_id")
  permissionId String @map("permission_id")

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@index([permissionId])
  @@map("role_permissions")
}

model UserRole {
  userId String @map("user_id")
  roleId String @map("role_id")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@index([roleId])
  @@map("user_roles")
}

model UserBranchAccess {
  userId   String @map("user_id")
  branchId String @map("branch_id")

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  branch Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@id([userId, branchId])
  @@index([branchId])
  @@map("user_branch_access")
}

model Device {
  id                 String   @id @default(uuid())
  companyId          String   @map("company_id")
  branchId           String   @map("branch_id")
  label              String  
  devicePublicKey     String  @unique @map("device_public_key")
  registeredBy       String   @map("registered_by")
  status             String   @default("pending") // pending/active/revoked
  appVersion         String?  @map("app_version")
  lastSeenAt         DateTime? @map("last_seen_at")
  lastBootstrapAt    DateTime? @map("last_bootstrap_at")
  lastRecoveryEpoch  Int      @default(0) @map("last_recovery_epoch")
  schemaVersion      String?  @map("schema_version")
  revokedAt          DateTime? @map("revoked_at")
  createdAt          DateTime @default(now()) @map("created_at")

  company           Company           @relation(fields: [companyId], references: [id], onDelete: Restrict)
  branch            Branch            @relation(fields: [branchId], references: [id])
  registeredByUser  User              @relation("DeviceRegistrant", fields: [registeredBy], references: [id])
  refreshTokens     RefreshToken[]
  documentLeases    DocumentNumberLease[]
  securityEvents    SecurityEvent[]
  auditLogs         AuditLog[]
  // Gap model backward relations
  stockBudgetLeases StockBudgetLease[] @relation("StockBudgetDevice")

  @@unique([companyId, branchId, label])
  @@index([companyId])
  @@index([branchId])
  @@index([status])
  @@index([lastSeenAt])
  @@map("devices")
}

model RefreshToken {
  id            String   @id @default(uuid())
  companyId     String   @map("company_id")
  userId        String   @map("user_id")
  tokenHash     String   @unique @map("token_hash")
  familyId      String   @map("family_id")
  deviceId      String?  @map("device_id")
  expiresAt     DateTime @map("expires_at")
  rotatedFromId String?  @map("rotated_from_id")
  revokedAt     DateTime? @map("revoked_at")
  revokeReason  String?  @map("revoke_reason")
  createdAt     DateTime @default(now()) @map("created_at")

  company     Company    @relation(fields: [companyId], references: [id], onDelete: Restrict)
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  device      Device?    @relation(fields: [deviceId], references: [id])
  rotatedFrom RefreshToken? @relation("RefreshTokenRotation", fields: [rotatedFromId], references: [id])
  rotatedTo   RefreshToken[] @relation("RefreshTokenRotation")

  @@index([companyId])
  @@index([userId])
  @@index([familyId])
  @@index([deviceId])
  @@index([expiresAt])
  @@index([revokedAt])
  @@map("refresh_tokens")
}

model SecurityEvent {
  id          String   @id @default(uuid())
  companyId   String   @map("company_id")
  userId      String?  @map("user_id")
  deviceId    String?  @map("device_id")
  eventType   String   @map("event_type")
  severity    String   @default("info") // info/warning/high/critical
  ipAddress   String?  @map("ip_address")
  userAgent   String?  @map("user_agent")
  metadata    String   @default("{}") // JSONB equivalent (SQLite TEXT)
  occurredAt  DateTime @default(now()) @map("occurred_at")

  company Company @relation(fields: [companyId], references: [id], onDelete: Restrict)
  user    User?    @relation(fields: [userId], references: [id])
  device  Device?  @relation(fields: [deviceId], references: [id])

  @@index([companyId])
  @@index([userId])
  @@index([deviceId])
  @@index([eventType])
  @@index([severity])
  @@index([occurredAt])
  @@map("security_events")
}

model CashierDevicePin {
  id        String   @id @default(uuid())
  companyId String   @map("company_id")
  userId    String   @map("user_id")
  deviceId  String   @map("device_id")
  pinHash   String   @map("pin_hash")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @map("updated_at")
  revokedAt DateTime? @map("revoked_at")

  @@unique([userId, deviceId])
  @@index([companyId])
  @@map("cashier_device_pins")
}

// ──────────────────────────────────────────────────────────────────────
// WebAuthn credentials (Step 3 — M0 iteration)
// Stores registered passkey/security-key credential for second-factor auth.
// Per §6 rule 2: WebAuthn is mandatory for owners/global_admins (in addition
// to TOTP). The credential ID is base64url-encoded; the public key is stored
// in COSE format. Counter is checked on every assertion to detect cloned
// authenticators.
// ──────────────────────────────────────────────────────────────────────

model WebAuthnCredential {
  id                String   @id @default(uuid())
  companyId         String   @map("company_id")
  userId            String   @map("user_id")
  credentialId      String   @unique @map("credential_id") // base64url
  publicKey         Bytes    @map("public_key") // COSE format
  counter           Int      @default(0)
  deviceType        String?  @map("device_type") // single_device | multi_device
  backedUp          Boolean  @default(false) @map("backed_up")
  transports        String   @default("[]") @map("transports") // JSON array
  name              String?  // user-assigned label
  createdAt         DateTime @default(now()) @map("created_at")
  lastUsedAt        DateTime? @map("last_used_at")
  revokedAt         DateTime? @map("revoked_at")

  company Company @relation(fields: [companyId], references: [id], onDelete: Restrict)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([userId])
  @@index([revokedAt])
  @@map("webauthn_credentials")
}

// WebAuthn challenge store — single-use challenges for registration/login
model WebAuthnChallenge {
  id        String   @id @default(uuid())
  companyId String   @map("company_id")
  userId    String?  @map("user_id") // null for login attempts before user identified
  challenge String   // base64url
  action    String   // registration | assertion
  expiresAt DateTime @map("expires_at")
  consumedAt DateTime? @map("consumed_at")
  createdAt DateTime @default(now()) @map("created_at")

  company Company @relation(fields: [companyId], references: [id], onDelete: Restrict)
  user    User?   @relation("WebAuthnChallengeUser", fields: [userId], references: [id])

  @@index([companyId])
  @@index([userId])
  @@index([expiresAt])
  @@index([consumedAt])
  @@map("webauthn_challenges")
}

// ──────────────────────────────────────────────────────────────────────
// §5.3 Numbering, Events, and Idempotency
// ──────────────────────────────────────────────────────────────────────

model DocumentSequence {
  id           String   @id @default(uuid())
  companyId    String   @map("company_id")
  branchId     String?  @map("branch_id")
  documentType String   @map("document_type")
  fiscalYear   Int      @map("fiscal_year")
  prefix       String  
  nextNumber   BigInt   @default(1) @map("next_number")
  padding      Int      @default(6)
  version      Int      @default(0)

  company Company @relation(fields: [companyId], references: [id], onDelete: Restrict)
  branch  Branch? @relation(fields: [branchId], references: [id])

  // SQLite cannot enforce partial UNIQUEs directly; we enforce in app code via
  // nextDocumentNumber() with deterministic locking.
  @@index([companyId, documentType, fiscalYear])
  @@index([companyId, branchId, documentType, fiscalYear])
  @@map("document_sequences")
}

model DocumentNumberLease {
  id           String   @id @default(uuid())
  companyId    String   @map("company_id")
  branchId     String   @map("branch_id")
  deviceId     String   @map("device_id")
  documentType String   @map("document_type")
  prefix       String  
  rangeStart   BigInt   @map("range_start")
  rangeEnd     BigInt   @map("range_end")
  nextNumber   BigInt   @map("next_number")
  expiresAt    DateTime @map("expires_at")
  status       String   @default("active") // active/exhausted/expired/revoked

  company Company @relation(fields: [companyId], references: [id], onDelete: Restrict)
  branch  Branch  @relation(fields: [branchId], references: [id])
  device  Device  @relation(fields: [deviceId], references: [id])

  @@index([companyId, documentType, prefix])
  @@index([branchId])
  @@index([deviceId])
  @@index([expiresAt])
  @@index([status])
  @@map("document_number_leases")
}

model IdempotencyRequest {
  id              String   @id @default(uuid())
  companyId       String   @map("company_id")
  userId          String?  @map("user_id")
  deviceId        String?  @map("device_id")
  idempotencyKey  String   @unique @map("idempotency_key")
  operation       String  
  requestHash     String   @map("request_hash")
  status          String   @default("processing") // processing/succeeded/failed
  resourceType    String?  @map("resource_type")
  resourceId      String?  @map("resource_id")
  responseStatus  Int?     @map("response_status")
  responseBody    String?  @map("response_body") // JSON
  lockedAt        DateTime @default(now()) @map("locked_at")
  completedAt     DateTime? @map("completed_at")
  expiresAt       DateTime @map("expires_at")

  // Note: SQLite cannot enforce UNIQUE(company_id, idempotency_key) where the
  // composite is the natural key — we use @unique on idempotency_key globally
  // and validate company_id match in the middleware.
  company Company @relation(fields: [companyId], references: [id], onDelete: Restrict)

  @@index([companyId])
  @@index([userId])
  @@index([deviceId])
  @@index([operation])
  @@index([status])
  @@index([resourceId])
  @@index([expiresAt])
  @@map("idempotency_requests")
}

model BusinessEvent {
  id           String   @id @default(uuid())
  companyId    String   @map("company_id")
  eventType    String   @map("event_type")
  sourceType   String   @map("source_type")
  sourceId     String   @map("source_id")
  correlationId String  @map("correlation_id")
  occurredAt   DateTime @default(now()) @map("occurred_at")

  company Company @relation(fields: [companyId], references: [id], onDelete: Restrict)
  // M2 backward relations
  stockMovements      StockMovement[]
  serialEvents        SerialEvent[]
  stockAdjustmentItems StockAdjustmentItem[]
  // M3 backward relations
  paymentAllocations  PaymentAllocation[]
  // M4 — accounting
  journalEntries      JournalEntry[]       @relation("JournalEntryEvent")
  // M5 — service part consumed
  servicePartConsumptions ServiceRequestPart[] @relation("ServicePartConsumedEvent")
  // M7 — outbox
  outboxEvents        OutboxEvent[]       @relation("OutboxBusinessEvent")
  // Gap model backward relations
  riskAssessments     RiskAssessment[]    @relation("RiskAssessmentEvent")
  customerAdvanceLedger CustomerAdvanceLedger[]
  supplierAdvanceLedger SupplierAdvanceLedger[]

  @@unique([companyId, eventType, sourceType, sourceId])
  @@index([companyId])
  @@index([eventType])
  @@index([sourceType, sourceId])
  @@index([correlationId])
  @@index([occurredAt])
  @@map("business_events")
}

model DocumentExchangeRate {
  id           String  @id @default(uuid())
  companyId    String  @map("company_id")
  currencyCode String  @map("currency_code")
  rateToBase   Decimal @map("rate_to_base")
  rateDate     DateTime @map("rate_date")

  currency Currency @relation(fields: [currencyCode], references: [code])

  @@index([companyId])
  @@index([currencyCode])
  @@map("document_exchange_rates")
}

// ──────────────────────────────────────────────────────────────────────
// §5.15 Audit, Approval, Statutory, and Reconciliation
// ──────────────────────────────────────────────────────────────────────

model AuditLog {
  id           String   @id @default(uuid())
  companyId    String   @map("company_id")
  userId       String?  @map("user_id")
  deviceId     String?  @map("device_id")
  correlationId String  @map("correlation_id")
  action       String  
  entityType   String   @map("entity_type")
  entityId     String   @map("entity_id")
  beforeValue  String?  @map("before_value") // JSONB
  afterValue   String?  @map("after_value") // JSONB
  clientIp     String?  @map("client_ip")
  syncIp       String?  @map("sync_ip")
  userAgent    String?  @map("user_agent")
  occurredAt   DateTime @default(now()) @map("occurred_at")

  company Company @relation(fields: [companyId], references: [id], onDelete: Restrict)
  user    User?    @relation(fields: [userId], references: [id])
  device  Device?  @relation(fields: [deviceId], references: [id])

  @@index([companyId])
  @@index([userId])
  @@index([deviceId])
  @@index([correlationId])
  @@index([action])
  @@index([entityType, entityId])
  @@index([occurredAt])
  @@map("audit_logs")
}

model ApprovalRequest {
  id            String   @id @default(uuid())
  companyId     String   @map("company_id")
  branchId      String?  @map("branch_id")
  requestType   String   @map("request_type")
  referenceType String   @map("reference_type")
  referenceId   String   @map("reference_id")
  requestedBy   String   @map("requested_by")
  approvedBy    String?  @map("approved_by")
  status        String   @default("pending") // pending/approved/rejected/cancelled/expired
  reason        String
  payload       String   @default("{}") // JSONB
  requestedAt   DateTime @default(now()) @map("requested_at")
  resolvedAt    DateTime? @map("resolved_at")
  waivedBy      String?  @map("waived_by")
  waiverReason  String?  @map("waiver_reason")

  company    Company @relation(fields: [companyId], references: [id], onDelete: Restrict)
  branch     Branch? @relation(fields: [branchId], references: [id])
  requestedByUser User @relation("ApprovalRequestedBy", fields: [requestedBy], references: [id])
  approvedByUser  User?  @relation("ApprovalApprovedBy", fields: [approvedBy], references: [id])
  waivedByUser    User?  @relation("ApprovalWaivedBy", fields: [waivedBy], references: [id])

  @@index([companyId])
  @@index([branchId])
  @@index([requestType])
  @@index([referenceType, referenceId])
  @@index([requestedBy])
  @@index([approvedBy])
  @@index([status])
  @@index([requestedAt])
  @@map("approval_requests")
}

model StatutoryDocument {
  id              String   @id @default(uuid())
  companyId       String   @map("company_id")
  branchId        String   @map("branch_id")
  documentType    String   @map("document_type") // VAT_6_3/VAT_6_1/VAT_6_2/VAT_9_1/withholding_certificate/other
  documentNo      String   @map("document_no")
  sourceType      String   @map("source_type")
  sourceId        String   @map("source_id")
  issueDate       DateTime @map("issue_date")
  taxPeriodStart  DateTime? @map("tax_period_start")
  taxPeriodEnd    DateTime? @map("tax_period_end")
  payloadSnapshot String   @map("payload_snapshot") @default("{}") // JSONB
  objectKey       String?  @map("object_key")
  status          String   @default("draft") // draft/issued/replaced/cancelled/filed
  replacementOfId String?  @map("replacement_of_id")
  issuedBy        String?  @map("issued_by")
  createdAt       DateTime @default(now()) @map("created_at")

  company        Company          @relation(fields: [companyId], references: [id], onDelete: Restrict)
  branch         Branch           @relation(fields: [branchId], references: [id])
  issuedByUser   User?            @relation(fields: [issuedBy], references: [id])
  replacementOf  StatutoryDocument? @relation("StatutoryReplacement", fields: [replacementOfId], references: [id])
  replacedBy     StatutoryDocument[] @relation("StatutoryReplacement")
  taxReturnPeriods TaxReturnPeriod[]

  @@unique([companyId, documentType, documentNo])
  @@index([companyId])
  @@index([branchId])
  @@index([documentType])
  @@index([sourceType, sourceId])
  @@index([issueDate])
  @@index([status])
  @@map("statutory_documents")
}

model TaxReturnPeriod {
  id                  String   @id @default(uuid())
  companyId           String   @map("company_id")
  periodStart         DateTime @map("period_start")
  periodEnd           DateTime @map("period_end")
  returnType          String   @default("VAT_9_1") @map("return_type") // VAT_9_1/withholding/other
  status              String   @default("open") // open/prepared/reviewed/filed/amended
  preparedDocumentId  String?  @map("prepared_document_id")
  filedAt             DateTime? @map("filed_at")
  filedReference      String?  @map("filed_reference")

  company           Company           @relation(fields: [companyId], references: [id], onDelete: Restrict)
  preparedDocument  StatutoryDocument? @relation(fields: [preparedDocumentId], references: [id])

  @@unique([companyId, returnType, periodStart, periodEnd])
  @@index([companyId])
  @@index([status])
  @@map("tax_return_periods")
}

model ReconciliationRun {
  id           String   @id @default(uuid())
  companyId    String   @map("company_id")
  runType      String   @default("nightly") @map("run_type") // nightly/manual/pre_close/post_restore
  startedAt    DateTime @default(now()) @map("started_at")
  completedAt  DateTime? @map("completed_at")
  status       String   @default("running") // running/passed/failed/partial
  initiatedBy  String?  @map("initiated_by")
  summary      String   @default("{}") // JSONB

  company       Company                 @relation(fields: [companyId], references: [id], onDelete: Restrict)
  initiatedByUser User?                 @relation(fields: [initiatedBy], references: [id])
  findings      ReconciliationFinding[]

  @@index([companyId])
  @@index([runType])
  @@index([startedAt])
  @@index([status])
  @@map("reconciliation_runs")
}

model ReconciliationFinding {
  id                   String   @id @default(uuid())
  companyId            String   @map("company_id")
  reconciliationRunId  String   @map("reconciliation_run_id")
  checkCode            String   @map("check_code")
  severity             String   @default("info") // info/warning/high/critical
  branchId             String?  @map("branch_id")
  referenceType        String?  @map("reference_type")
  referenceId          String?  @map("reference_id")
  expectedValue        Decimal? @map("expected_value")
  actualValue          Decimal? @map("actual_value")
  variance             Decimal?
  details              String   @default("{}") // JSONB
  status               String   @default("open") // open/acknowledged/resolved/false_positive
  resolvedBy           String?  @map("resolved_by")
  resolvedAt           DateTime? @map("resolved_at")

  company              Company            @relation(fields: [companyId], references: [id], onDelete: Restrict)
  reconciliationRun    ReconciliationRun  @relation(fields: [reconciliationRunId], references: [id])
  branch               Branch?            @relation(fields: [branchId], references: [id])
  resolvedByUser       User?              @relation(fields: [resolvedBy], references: [id])

  @@index([companyId])
  @@index([reconciliationRunId])
  @@index([checkCode])
  @@index([severity])
  @@index([branchId])
  @@index([referenceId])
  @@index([status])
  @@map("reconciliation_findings")
}

model RecoveryEpoch {
  id          String   @id @default(uuid())
  companyId   String   @map("company_id")
  epochNumber Int      @map("epoch_number")
  reason      String  
  declaredBy  String   @map("declared_by")
  declaredAt  DateTime @default(now()) @map("declared_at")

  company Company @relation(fields: [companyId], references: [id], onDelete: Restrict)

  @@index([companyId, epochNumber])
  @@map("recovery_epochs")
}

model IntegrationCredential {
  id                    String   @id @default(uuid())
  companyId             String   @map("company_id")
  provider              String  
  label                 String  
  credentialCiphertext  Bytes    @map("credential_ciphertext")
  keyVersion            Int      @default(1) @map("key_version")
  status                String   @default("active") // active/disabled/expired
  lastRotatedAt         DateTime @default(now()) @map("last_rotated_at")
  createdBy             String   @map("created_by")

  company Company @relation(fields: [companyId], references: [id], onDelete: Restrict)
  creator  User    @relation(fields: [createdBy], references: [id])

  @@unique([companyId, provider, label])
  @@index([companyId])
  @@index([status])
  @@map("integration_credentials")
}
// prisma/m1-additions.prisma
// M1 schema additions — appended to schema.prisma via cat.
// Models for §5.4 (Catalogue, Pricing, Tax) + §5.14A (Configuration, Feature Flags,
// Templates, Translations, POS Profiles, Languages, Notifications, Support).

// ──────────────────────────────────────────────────────────────────────
// §5.4 Catalogue, Pricing, and Tax
// ──────────────────────────────────────────────────────────────────────

model Category {
  id         String   @id @default(uuid())
  companyId  String   @map("company_id")
  parentId   String?  @map("parent_id")
  name       String
  code       String
  isActive   Boolean  @default(true) @map("is_active")
  deletedAt  DateTime? @map("deleted_at")

  company    Company   @relation(fields: [companyId], references: [id], onDelete: Restrict)
  parent     Category? @relation("CategoryTree", fields: [parentId], references: [id])
  children   Category[] @relation("CategoryTree")
  products   Product[]
  discountPolicies DiscountPolicy[] @relation("DiscountPolicyCategory")
  // M2 backward relations
  stockCounts StockCount[]

  @@unique([companyId, code])
  @@unique([companyId, parentId, name])
  @@index([companyId])
  @@index([parentId])
  @@index([isActive])
  @@map("categories")
}

model Brand {
  id         String   @id @default(uuid())
  companyId  String   @map("company_id")
  name       String
  isActive   Boolean  @default(true) @map("is_active")
  deletedAt  DateTime? @map("deleted_at")

  company Company  @relation(fields: [companyId], references: [id], onDelete: Restrict)
  products Product[]
  // M2 backward relations
  stockCounts StockCount[]

  @@unique([companyId, name])
  @@index([companyId])
  @@map("brands")
}

model Unit {
  id                 String   @id @default(uuid())
  companyId          String   @map("company_id")
  name               String
  code               String
  baseUnitId         String?  @map("base_unit_id")
  conversionFactor   Decimal  @default(1) @map("conversion_factor")
  allowFractional    Boolean  @default(false) @map("allow_fractional")

  company   Company  @relation(fields: [companyId], references: [id], onDelete: Restrict)
  baseUnit  Unit?    @relation("UnitTree", fields: [baseUnitId], references: [id])
  derived   Unit[]   @relation("UnitTree")
  products  Product[]
  productUnitOptions ProductUnitOption[]
  productBarcodes ProductBarcode[]
  comboComponents  ProductComboItem[]

  @@unique([companyId, code])
  @@index([companyId])
  @@index([baseUnitId])
  @@map("units")
}

model CustomerGroup {
  id                    String  @id @default(uuid())
  companyId             String  @map("company_id")
  name                  String
  defaultDiscountRate   Decimal @default(0) @map("default_discount_rate")
  creditLimitDefault    Decimal @default(0) @map("credit_limit_default")
  isActive              Boolean @default(true) @map("is_active")

  company Company @relation(fields: [companyId], references: [id], onDelete: Restrict)
  discountPolicies DiscountPolicy[]
  productPrices ProductPrice[]
  // M2 backward relations
  customers Customer[]

  @@unique([companyId, name])
  @@index([companyId])
  @@map("customer_groups")
}

model Product {
  id                    String   @id @default(uuid())
  companyId             String   @map("company_id")
  name                  String
  code                  String
  categoryId            String   @map("category_id")
  brandId               String?  @map("brand_id")
  unitId                String   @map("unit_id")
  productType           String   @default("standard") @map("product_type") // standard/combo/service/digital
  isSerialized          Boolean  @default(false) @map("is_serialized")
  trackBatches          Boolean  @default(false) @map("track_batches")
  warrantyPeriodMonths  Int?     @map("warranty_period_months")
  referenceCost         Decimal  @default(0) @map("reference_cost")
  defaultPrice          Decimal  @default(0) @map("default_price")
  defaultTaxCodeId      String?  @map("default_tax_code_id")
  alertQuantity         Decimal  @default(0) @map("alert_quantity")
  shortDescription      String?  @map("short_description")
  description           String?
  isFeatured            Boolean  @default(false) @map("is_featured")
  isActive              Boolean  @default(true) @map("is_active")
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @default(now()) @map("updated_at")
  deletedAt             DateTime? @map("deleted_at")

  company          Company       @relation(fields: [companyId], references: [id], onDelete: Restrict)
  category         Category      @relation(fields: [categoryId], references: [id])
  brand            Brand?        @relation(fields: [brandId], references: [id])
  unit             Unit          @relation(fields: [unitId], references: [id])
  defaultTaxCode   TaxCode?      @relation(fields: [defaultTaxCodeId], references: [id])
  barcodes         ProductBarcode[]
  unitOptions      ProductUnitOption[]
  comboAsParent    ProductComboItem[] @relation("ComboParent")
  comboAsComponent ProductComboItem[] @relation("ComboComponent")
  discountPolicies DiscountPolicy[]
  prices           ProductPrice[]
  // M2 backward relations
  warehouseStocks  WarehouseStock[]
  stockMovements   StockMovement[]
  stockReservations StockReservation[]
  productBatches   ProductBatch[]
  stockCountItems  StockCountItem[]
  stockAdjustmentItems StockAdjustmentItem[]
  productSerials   ProductSerial[]
  purchaseItems    PurchaseItem[]
  transferItems    TransferItem[]
  // M3 backward relations
  quotationItems   QuotationItem[]
  saleItems        SaleItem[]
  // M4 — accounting
  journalLines     JournalLine[]     @relation("JournalLineProduct")
  // M5 — service parts
  serviceRequestParts ServiceRequestPart[]
  // Gap model backward relations
  stockBudgetLeases StockBudgetLease[] @relation("StockBudgetProduct")

  @@unique([companyId, code])
  @@index([companyId])
  @@index([categoryId])
  @@index([brandId])
  @@index([unitId])
  @@index([productType])
  @@index([isSerialized])
  @@index([trackBatches])
  @@index([isFeatured])
  @@index([isActive])
  @@index([deletedAt])
  @@map("products")
}

model MediaAsset {
  id               String   @id @default(uuid())
  companyId        String   @map("company_id")
  objectKey        String   @map("object_key")
  originalFilename String   @map("original_filename")
  mimeType         String   @map("mime_type")
  sizeBytes        Int      @default(0) @map("size_bytes")
  sha256           String
  widthPx          Int?     @map("width_px")
  heightPx         Int?     @map("height_px")
  altText          String?  @map("alt_text")
  scanStatus       String   @default("pending") @map("scan_status") // pending/clean/quarantined/rejected
  createdBy        String   @map("created_by")
  createdAt        DateTime @default(now()) @map("created_at")
  deletedAt        DateTime? @map("deleted_at")

  company Company @relation(fields: [companyId], references: [id], onDelete: Restrict)
  creator  User   @relation("MediaCreatedBy", fields: [createdBy], references: [id])
  entityLinks EntityMediaLink[]
  exportJobs ReportExportJob[]

  @@unique([companyId, objectKey])
  @@index([companyId])
  @@index([mimeType])
  @@index([sha256])
  @@index([scanStatus])
  @@index([deletedAt])
  @@map("media_assets")
}

model EntityMediaLink {
  id           String   @id @default(uuid())
  companyId    String   @map("company_id")
  mediaAssetId String   @map("media_asset_id")
  entityType   String   @map("entity_type") // company/branch/product/category/brand/employee/service_request/support_ticket/expense
  entityId     String   @map("entity_id")
  mediaRole    String   @map("media_role") // logo/primary/gallery/document/receipt/evidence/attachment
  sortOrder    Int      @default(0) @map("sort_order")
  createdAt    DateTime @default(now()) @map("created_at")

  company Company   @relation(fields: [companyId], references: [id], onDelete: Restrict)
  mediaAsset MediaAsset @relation(fields: [mediaAssetId], references: [id])

  @@unique([companyId, entityType, entityId, mediaAssetId, mediaRole])
  @@index([companyId])
  @@index([mediaAssetId])
  @@index([entityType])
  @@index([entityId])
  @@index([mediaRole])
  @@map("entity_media_links")
}

model ProductBarcode {
  id                String   @id @default(uuid())
  companyId         String   @map("company_id")
  productId         String   @map("product_id")
  code              String
  symbology         String   @default("CODE128") // CODE128/CODE39/EAN8/EAN13/UPCA/QR
  unitId            String?  @map("unit_id")
  packageQuantity   Decimal  @default(1) @map("package_quantity")
  isPrimary         Boolean  @default(false) @map("is_primary")
  createdAt         DateTime @default(now()) @map("created_at")

