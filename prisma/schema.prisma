  // M3 backward relations
  saleItemTaxes      SaleItemTax[]
  // M4 — input/output GL accounts
  inputAccount   ChartOfAccount? @relation("TaxCompInputAccount", fields: [inputAccountId], references: [id])
  outputAccount  ChartOfAccount? @relation("TaxCompOutputAccount", fields: [outputAccountId], references: [id])
  // Gap model backward relations
  expenseItemTaxes   ExpenseItemTax[]

  @@unique([companyId, componentCode])
  @@index([companyId])
  @@index([componentType])
  @@map("tax_components")
}

model TaxCodeComponent {
  taxCodeId       String @map("tax_code_id")
  taxComponentId  String @map("tax_component_id")

  taxCode       TaxCode       @relation(fields: [taxCodeId], references: [id], onDelete: Cascade)
