  @@unique([companyId, code])
  @@index([companyId])
  @@index([withholdingType])
  @@index([appliesTo])
  @@index([effectiveFrom])
  @@index([effectiveTo])
  @@index([isActive])
  @@map("withholding_rules")
}

// ──────────────────────────────────────────────────────────────────────
// §5.14A Configuration, Feature Flags, Templates, Translations, POS Profiles
// ──────────────────────────────────────────────────────────────────────

model ConfigurationDefinition {
  key            String  @id
  module         String
  valueType      String  @map("value_type") // string/integer/decimal/boolean/json
  jsonSchema     String? @map("json_schema") // JSONB
  allowedScopes  String  @default("company,branch") @map("allowed_scopes") // CSV
  isSecret       Boolean @default(false) @map("is_secret")
  defaultValue   String? @map("default_value") // JSONB
  description    String

  values ConfigurationValue[]

  @@index([module])
  @@map("configuration_definitions")
}

model ConfigurationValue {
  id              String   @id @default(uuid())
  companyId       String   @map("company_id")
  definitionKey   String   @map("definition_key")
  scopeType       String   @default("company") @map("scope_type") // company/branch/warehouse/pos_profile/user
  scopeId         String   @map("scope_id")
  value           String   @default("{}") // JSONB
  version         Int      @default(1)
  updatedBy       String   @map("updated_by")
  updatedAt       DateTime @default(now()) @map("updated_at")

  company     Company                @relation(fields: [companyId], references: [id], onDelete: Restrict)
  definition  ConfigurationDefinition @relation(fields: [definitionKey], references: [key])
  updater     User                   @relation("ConfigUpdatedBy", fields: [updatedBy], references: [id])

  @@unique([companyId, definitionKey, scopeType, scopeId])
  @@index([companyId])
  @@index([definitionKey])
  @@index([scopeType, scopeId])
  @@map("configuration_values")
}

model PosProfile {
  id                      String   @id @default(uuid())
  companyId               String   @map("company_id")
  branchId                String   @map("branch_id")
  name                    String
  defaultWarehouseId      String   @map("default_warehouse_id")
  defaultCustomerId       String?  @map("default_customer_id")
  receiptTemplateId       String?  @map("receipt_template_id")
  invoiceTemplateId       String?  @map("invoice_template_id")
  holdReservationMinutes  Int      @default(15) @map("hold_reservation_minutes")
  allowDueSale            Boolean  @default(false) @map("allow_due_sale")
  requireCustomerForDue   Boolean  @default(true) @map("require_customer_for_due")
  printerMode             String   @default("browser") @map("printer_mode") // browser/escpos_bridge/system
  isActive                Boolean  @default(true) @map("is_active")

  company            Company           @relation(fields: [companyId], references: [id], onDelete: Restrict)
  branch             Branch            @relation(fields: [branchId], references: [id])
  defaultWarehouse   Warehouse         @relation(fields: [defaultWarehouseId], references: [id])
  receiptTemplate    DocumentTemplate? @relation("PosProfileReceiptTemplate", fields: [receiptTemplateId], references: [id])
  invoiceTemplate    DocumentTemplate? @relation("PosProfileInvoiceTemplate", fields: [invoiceTemplateId], references: [id])

  @@unique([companyId, branchId, name])
  @@index([companyId])
  @@index([branchId])
  @@index([isActive])
  @@map("pos_profiles")
}

model DocumentTemplate {
  id             String   @id @default(uuid())
  companyId      String   @map("company_id")
  templateType   String   @map("template_type") // receipt80/a4_invoice/quotation/warranty_card/service_receipt/barcode_sheet/statutory
  name           String
  locale         String
  version        Int      @default(1)
  templateSchema String   @default("{}") @map("template_schema") // JSONB
  isActive       Boolean  @default(true) @map("is_active")
  approvedBy     String?  @map("approved_by")
  createdAt      DateTime @default(now()) @map("created_at")

  company         Company         @relation(fields: [companyId], references: [id], onDelete: Restrict)
  approver        User?           @relation("TemplateApprovedBy", fields: [approvedBy], references: [id])
  posProfilesReceipt PosProfile[] @relation("PosProfileReceiptTemplate")
  posProfilesInvoice PosProfile[] @relation("PosProfileInvoiceTemplate")

  @@unique([companyId, templateType, name, locale, version])
  @@index([companyId])
  @@index([templateType])
  @@index([locale])
  @@index([isActive])
  @@map("document_templates")
}

model SupportedLanguage {
