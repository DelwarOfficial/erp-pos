  createdAt       DateTime @default(now()) @map("created_at")

  company Company       @relation(fields: [companyId], references: [id], onDelete: Restrict)
  ticket  SupportTicket @relation(fields: [supportTicketId], references: [id])
  author  User          @relation("SupportTicketAuthor", fields: [authorUserId], references: [id])

  @@index([companyId])
  @@index([supportTicketId])
  @@index([authorUserId])
  @@index([createdAt])
  @@map("support_ticket_messages")
}

model CommunicationTemplate {
  id               String   @id @default(uuid())
  companyId        String   @map("company_id")
  code             String
  channel          String   @default("sms") // sms/email/push/in_app
  purpose          String   @default("transactional") // transactional/marketing/internal
  locale           String
  subjectTemplate  String?  @map("subject_template")
  bodyTemplate     String   @map("body_template")
  allowedTokens    String   @default("[]") @map("allowed_tokens") // JSONB array
  version          Int      @default(1)
  isActive         Boolean  @default(true) @map("is_active")
  approvedBy       String?  @map("approved_by")
  createdAt        DateTime @default(now()) @map("created_at")

  company Company           @relation(fields: [companyId], references: [id], onDelete: Restrict)
  language SupportedLanguage @relation(fields: [locale], references: [locale])
  approver User?            @relation("CommTemplateApprovedBy", fields: [approvedBy], references: [id])
  // Gap model backward relations
