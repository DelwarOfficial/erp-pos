  effectiveFrom    DateTime @map("effective_from")
  effectiveTo      DateTime? @map("effective_to")
  isActive         Boolean  @default(true) @map("is_active")

  company     Company            @relation(fields: [companyId], references: [id], onDelete: Restrict)
  components  TaxCodeComponent[]
  products    Product[]

  @@unique([companyId, code])
  @@index([companyId])
  @@index([effectiveFrom])
  @@index([effectiveTo])
  @@index([isActive])
  @@map("tax_codes")
}

model TaxComponent {
  id                  String   @id @default(uuid())
  companyId           String   @map("company_id")
  componentCode       String   @map("component_code")
  name                String
  componentType       String   @default("VAT") @map("component_type") // VAT/SD/RD/ATV/OTHER
  rate                Decimal  @default(0)
  calculationOrder    Int      @default(1) @map("calculation_order")
  compoundOnPrevious  Boolean  @default(false) @map("compound_on_previous")
  inputAccountId      String?  @map("input_account_id")
  outputAccountId     String?  @map("output_account_id")
  effectiveFrom       DateTime @map("effective_from")
  effectiveTo         DateTime? @map("effective_to")

  company Company           @relation(fields: [companyId], references: [id], onDelete: Restrict)
  taxCodeComponents TaxCodeComponent[]
