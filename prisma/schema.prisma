  unit     Unit?   @relation(fields: [unitId], references: [id])

  @@unique([companyId, code])
  @@index([companyId])
  @@index([productId])
  @@index([symbology])
  @@index([unitId])
  @@index([isPrimary])
  @@map("product_barcodes")
}

model ProductUnitOption {
