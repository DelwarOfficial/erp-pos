model WarehouseStock {
  id                String   @id @default(uuid())
  companyId         String   @map("company_id")
  warehouseId       String   @map("warehouse_id")
  productId         String   @map("product_id")
  qtyOnHand         Decimal  @default(0) @map("qty_on_hand")
  qtyReserved       Decimal  @default(0) @map("qty_reserved")
  qtyInTransitOut   Decimal  @default(0) @map("qty_in_transit_out")
  qtyDamaged        Decimal  @default(0) @map("qty_damaged")
  movingAverageCost Decimal  @default(0) @map("moving_average_cost")
  version           Int      @default(0)
  updatedAt         DateTime @default(now()) @map("updated_at")

  company    Company    @relation(fields: [companyId], references: [id], onDelete: Restrict)
  warehouse  Warehouse  @relation(fields: [warehouseId], references: [id])
  product    Product    @relation(fields: [productId], references: [id])

  @@unique([companyId, warehouseId, productId])
  @@index([companyId])
  @@index([warehouseId])
  @@index([productId])
  @@map("warehouse_stocks")
}

model StockMovement {
  id                   String   @id @default(uuid())
  companyId            String   @map("company_id")
  eventId              String   @map("event_id")
  eventLineNo          Int      @map("event_line_no")
  warehouseId          String   @map("warehouse_id")
  productId            String   @map("product_id")
  stockBucket          String   @default("on_hand") @map("stock_bucket")
  movementType         String   @map("movement_type")
  qtyDelta             Decimal  @map("qty_delta")
  unitCost             Decimal  @map("unit_cost")
  totalCostDelta       Decimal  @map("total_cost_delta")
  referenceType        String   @map("reference_type")
  referenceId          String   @map("reference_id")
  sourceLineId         String?  @map("source_line_id")
  reversalOfMovementId String?  @map("reversal_of_movement_id")
  effectiveAt          DateTime @map("effective_at")
  postedAt             DateTime @default(now()) @map("posted_at")
  createdBy            String   @map("created_by")
  metadata             String   @default("{}")

  company        Company        @relation(fields: [companyId], references: [id], onDelete: Restrict)
  businessEvent  BusinessEvent  @relation(fields: [eventId], references: [id])
  warehouse      Warehouse      @relation(fields: [warehouseId], references: [id])
  product        Product        @relation(fields: [productId], references: [id])
  reversalOf     StockMovement? @relation("StockMovementReversal", fields: [reversalOfMovementId], references: [id])
  reversedBy     StockMovement[] @relation("StockMovementReversal")
  batchLinks     StockMovementBatch[]
  serialEvents   SerialEvent[]

  @@unique([companyId, eventId, eventLineNo])
  @@index([companyId])
  @@index([eventId])
  @@index([warehouseId])
  @@index([productId])
  @@index([stockBucket])
  @@index([movementType])
  @@index([referenceType, referenceId])
  @@index([effectiveAt])
  @@index([postedAt])
  @@index([reversalOfMovementId])
  @@map("stock_movements")
}

model StockReservation {
  id              String   @id @default(uuid())
  companyId       String   @map("company_id")
  warehouseId     String   @map("warehouse_id")
  productId       String   @map("product_id")
  reservationType String   @map("reservation_type")
  referenceId     String   @map("reference_id")
  qty             Decimal
  status          String   @default("active")
  expiresAt       DateTime? @map("expires_at")
  consumedAt      DateTime? @map("consumed_at")
  releasedAt      DateTime? @map("released_at")
  createdAt       DateTime @default(now()) @map("created_at")

  company       Company   @relation(fields: [companyId], references: [id], onDelete: Restrict)
  warehouse     Warehouse @relation(fields: [warehouseId], references: [id])
  product       Product   @relation(fields: [productId], references: [id])
  transferItems TransferItem[]
  // M2 — serials currently held by this reservation
  currentSerials ProductSerial[]

  @@unique([companyId, reservationType, referenceId, productId, warehouseId])
  @@index([companyId])
  @@index([warehouseId])
  @@index([productId])
  @@index([reservationType, referenceId])
  @@index([status])
  @@index([expiresAt])
  @@map("stock_reservations")
}

model ProductBatch {
  id            String   @id @default(uuid())
  companyId     String   @map("company_id")
  productId     String   @map("product_id")
  warehouseId   String   @map("warehouse_id")
  batchNo       String   @map("batch_no")
  manufacturedAt DateTime? @map("manufactured_at")
  expiryDate    DateTime? @map("expiry_date")
  qtyOnHand     Decimal  @default(0) @map("qty_on_hand")
  qtyReserved   Decimal  @default(0) @map("qty_reserved")
  status        String   @default("active")

  company        Company   @relation(fields: [companyId], references: [id], onDelete: Restrict)
  product        Product   @relation(fields: [productId], references: [id])
  warehouse      Warehouse @relation(fields: [warehouseId], references: [id])
  movementBatches StockMovementBatch[]
  countItems     StockCountItem[]
  // M2 — adjustment items linked to this batch
  adjustmentItems StockAdjustmentItem[]

  @@unique([companyId, productId, warehouseId, batchNo])
  @@index([companyId])
  @@index([productId])
  @@index([warehouseId])
  @@index([expiryDate])
  @@index([status])
  @@map("product_batches")
}

model StockMovementBatch {
  stockMovementId String  @map("stock_movement_id")
  productBatchId  String  @map("product_batch_id")
  companyId       String  @map("company_id")
  qty             Decimal
  overrideReason  String? @map("override_reason")

  stockMovement StockMovement @relation(fields: [stockMovementId], references: [id], onDelete: Restrict)
  productBatch  ProductBatch  @relation(fields: [productBatchId], references: [id], onDelete: Restrict)
  company       Company       @relation(fields: [companyId], references: [id], onDelete: Restrict)

  @@id([stockMovementId, productBatchId])
  @@index([productBatchId])
  @@map("stock_movement_batches")
}

model ProductSerial {
  id                       String   @id @default(uuid())
  companyId                String   @map("company_id")
  productId                String   @map("product_id")
  serialNumber             String   @map("serial_number")
  status                   String   @default("in_stock")
  currentWarehouseId       String?  @map("current_warehouse_id")
  currentReservationId     String?  @map("current_reservation_id")
  originatingPurchaseItemId String? @map("originating_purchase_item_id")
  soldSaleItemId           String?  @map("sold_sale_item_id")
  warrantyStartDate        DateTime? @map("warranty_start_date")
  warrantyExpiryDate       DateTime? @map("warranty_expiry_date")
  version                  Int      @default(0)
  createdAt                DateTime @default(now()) @map("created_at")
  updatedAt                DateTime @default(now()) @map("updated_at")

  company            Company           @relation(fields: [companyId], references: [id], onDelete: Restrict)
  product            Product           @relation(fields: [productId], references: [id])
  currentWarehouse   Warehouse?        @relation(fields: [currentWarehouseId], references: [id])
  currentReservation StockReservation? @relation(fields: [currentReservationId], references: [id])
  originatingPurchaseItem PurchaseItem? @relation(fields: [originatingPurchaseItemId], references: [id])
  serialEvents       SerialEvent[]
  receivingSerials   PurchaseReceivingItemSerial[]
  returnSerials      PurchaseReturnItemSerial[]
  // M2 — transfer serial links
  transferItemSerials TransferItemSerial[]
  // M2 — stock adjustment serial links
  stockAdjustmentItemSerials StockAdjustmentItemSerial[]
  // M2 — stock count serial links
  stockCountSerials StockCountSerial[]
  // M3 backward relations
  saleItemSerials      SaleItemSerial[]
  saleReturnItemSerials SaleReturnItemSerial[]
  // M5 — service + warranty
  serviceRequests  ServiceRequest[]
  warrantyClaimReplacements WarrantyClaim[]

  @@unique([companyId, serialNumber])
  @@index([companyId])
  @@index([productId])
  @@index([status])
  @@index([currentWarehouseId])
  @@index([currentReservationId])
  @@index([warrantyExpiryDate])
  @@map("product_serials")
}

model SerialEvent {
  id              String   @id @default(uuid())
  companyId       String   @map("company_id")
  serialId        String   @map("serial_id")
  eventId         String   @map("event_id")
  eventLineNo     Int      @map("event_line_no")
  eventType       String   @map("event_type")
  fromStatus      String?  @map("from_status")
  toStatus        String   @map("to_status")
  fromWarehouseId String?  @map("from_warehouse_id")
  toWarehouseId   String?  @map("to_warehouse_id")
  stockMovementId String?  @map("stock_movement_id")
  referenceType   String   @map("reference_type")
  referenceId     String   @map("reference_id")
  occurredAt      DateTime @default(now()) @map("occurred_at")
  createdBy       String   @map("created_by")

  company       Company       @relation(fields: [companyId], references: [id], onDelete: Restrict)
  serial        ProductSerial @relation(fields: [serialId], references: [id])
  businessEvent BusinessEvent @relation(fields: [eventId], references: [id])
  stockMovement StockMovement? @relation(fields: [stockMovementId], references: [id])
  fromWarehouse Warehouse?    @relation("SerialEventFromWh", fields: [fromWarehouseId], references: [id])
  toWarehouse   Warehouse?    @relation("SerialEventToWh", fields: [toWarehouseId], references: [id])

  @@unique([companyId, eventId, eventLineNo])
  @@index([companyId])
  @@index([serialId])
  @@index([eventId])
  @@index([eventType])
  @@index([referenceType, referenceId])
  @@index([occurredAt])
  @@map("serial_events")
}

// ──────────────────────────────────────────────────────────────────────
// §5.5A Stock Count, Adjustment
// ──────────────────────────────────────────────────────────────────────

model InventoryReasonCode {
  id                       String  @id @default(uuid())
  companyId                String  @map("company_id")
  code                     String
  name                     String
  reasonType               String  @default("adjustment") @map("reason_type")
  requiresApproval         Boolean @default(false) @map("requires_approval")
  defaultExpenseAccountId  String? @map("default_expense_account_id")
  isActive                 Boolean @default(true) @map("is_active")

  company Company @relation(fields: [companyId], references: [id], onDelete: Restrict)
  // M2 backward relations
  stockCountItems  StockCountItem[]
  stockAdjustments StockAdjustment[]

  @@unique([companyId, code])
  @@index([companyId])
  @@index([reasonType])
  @@map("inventory_reason_codes")
}

model StockCount {
  id                    String   @id @default(uuid())
  companyId             String   @map("company_id")
  branchId              String   @map("branch_id")
  warehouseId           String   @map("warehouse_id")
  referenceNo           String   @map("reference_no")
  scopeType             String   @default("all") @map("scope_type")
  categoryId            String?  @map("category_id")
  brandId               String?  @map("brand_id")
  status                String   @default("draft")
  blindCount            Boolean  @default(true) @map("blind_count")
  snapshotAt            DateTime? @map("snapshot_at")
  movementFreezePolicy  String   @default("warn") @map("movement_freeze_policy")
  notes                 String?
  createdBy             String   @map("created_by")
  reviewedBy            String?  @map("reviewed_by")
  postedBy              String?  @map("posted_by")
  createdAt             DateTime @default(now()) @map("created_at")
  postedAt              DateTime? @map("posted_at")

  company    Company    @relation(fields: [companyId], references: [id], onDelete: Restrict)
  branch     Branch     @relation(fields: [branchId], references: [id])
  warehouse  Warehouse  @relation(fields: [warehouseId], references: [id])
  category   Category?  @relation(fields: [categoryId], references: [id])
  brand      Brand?     @relation(fields: [brandId], references: [id])
  items      StockCountItem[]
  adjustments StockAdjustment[]

  @@unique([companyId, referenceNo])
  @@index([companyId])
  @@index([branchId])
  @@index([warehouseId])
  @@index([status])
  @@map("stock_counts")
}

model StockCountItem {
  id                String   @id @default(uuid())
  companyId         String   @map("company_id")
  stockCountId      String   @map("stock_count_id")
  productId         String   @map("product_id")
  batchId           String?  @map("batch_id")
  expectedQuantity  Decimal  @map("expected_quantity")
  countedQuantity   Decimal? @map("counted_quantity")
  varianceQuantity  Decimal? @map("variance_quantity")
  reasonCodeId      String?  @map("reason_code_id")
  countNote         String?  @map("count_note")

  company    Company           @relation(fields: [companyId], references: [id], onDelete: Restrict)
  stockCount StockCount        @relation(fields: [stockCountId], references: [id], onDelete: Restrict)
  product    Product           @relation(fields: [productId], references: [id])
  batch      ProductBatch?     @relation(fields: [batchId], references: [id])
  reasonCode InventoryReasonCode? @relation(fields: [reasonCodeId], references: [id])
  serials    StockCountSerial[]

  @@index([companyId])
  @@index([stockCountId])
  @@index([productId])
  @@index([batchId])
  @@map("stock_count_items")
}

model StockCountSerial {
  id                  String   @id @default(uuid())
  companyId           String   @map("company_id")
  stockCountItemId    String   @map("stock_count_item_id")
  serialId            String?  @map("serial_id")
  scannedSerialNumber String   @map("scanned_serial_number")
  expectedPresent     Boolean  @default(true) @map("expected_present")
  countedPresent      Boolean  @default(false) @map("counted_present")
  resolution          String   @default("matched")

  company        Company        @relation(fields: [companyId], references: [id], onDelete: Restrict)
  stockCountItem StockCountItem @relation(fields: [stockCountItemId], references: [id])
  serial         ProductSerial?  @relation(fields: [serialId], references: [id])

  @@unique([stockCountItemId, scannedSerialNumber])
  @@index([companyId])
  @@index([stockCountItemId])
  @@index([serialId])
  @@index([resolution])
  @@map("stock_count_serials")
}

model StockAdjustment {
  id                  String   @id @default(uuid())
  companyId           String   @map("company_id")
  branchId            String   @map("branch_id")
  warehouseId         String   @map("warehouse_id")
  referenceNo         String   @map("reference_no")
  clientTxnId         String   @map("client_txn_id")
  adjustmentType      String   @default("adjustment") @map("adjustment_type")
  reasonCodeId        String   @map("reason_code_id")
  sourceStockCountId  String?  @map("source_stock_count_id")
  reversalOfId        String?  @map("reversal_of_id")
  status              String   @default("draft")
  businessDate        DateTime @map("business_date")
  notes               String
  approvalRequestId   String?  @map("approval_request_id")
  journalEntryId      String?  @map("journal_entry_id")
  createdBy           String   @map("created_by")
  approvedBy          String?  @map("approved_by")
  postedAt            DateTime? @map("posted_at")
  createdAt           DateTime @default(now()) @map("created_at")

  company         Company          @relation(fields: [companyId], references: [id], onDelete: Restrict)
  branch          Branch           @relation(fields: [branchId], references: [id])
  warehouse       Warehouse        @relation(fields: [warehouseId], references: [id])
  reasonCode      InventoryReasonCode @relation(fields: [reasonCodeId], references: [id])
  sourceStockCount StockCount?     @relation(fields: [sourceStockCountId], references: [id])
  reversalOf      StockAdjustment? @relation("StockAdjustmentReversal", fields: [reversalOfId], references: [id])
  reversedBy      StockAdjustment[] @relation("StockAdjustmentReversal")
  items           StockAdjustmentItem[]

  @@unique([companyId, referenceNo])
  @@unique([companyId, clientTxnId])
  @@index([companyId])
  @@index([branchId])
  @@index([warehouseId])
  @@index([adjustmentType])
  @@index([reasonCodeId])
  @@index([sourceStockCountId])
  @@index([reversalOfId])
  @@index([status])
  @@index([businessDate])
  @@map("stock_adjustments")
}

model StockAdjustmentItem {
  id                  String   @id @default(uuid())
  companyId           String   @map("company_id")
  stockAdjustmentId   String   @map("stock_adjustment_id")
  lineNo              Int      @map("line_no")
  productId           String   @map("product_id")
  batchId             String?  @map("batch_id")
  quantityDelta       Decimal  @map("quantity_delta")
  unitCostSnapshot    Decimal  @map("unit_cost_snapshot")
  valueDelta          Decimal  @map("value_delta")
  eventId             String?  @map("event_id")

  company          Company          @relation(fields: [companyId], references: [id], onDelete: Restrict)
  stockAdjustment  StockAdjustment  @relation(fields: [stockAdjustmentId], references: [id])
  product          Product          @relation(fields: [productId], references: [id])
  batch            ProductBatch?    @relation(fields: [batchId], references: [id])
  businessEvent    BusinessEvent?   @relation(fields: [eventId], references: [id])
  serials          StockAdjustmentItemSerial[]

  @@unique([stockAdjustmentId, lineNo])
  @@index([companyId])
  @@index([stockAdjustmentId])
  @@index([productId])
  @@index([batchId])
  @@index([eventId])
  @@map("stock_adjustment_items")
}

model StockAdjustmentItemSerial {
  stockAdjustmentItemId String  @map("stock_adjustment_item_id")
  serialId              String  @map("serial_id")
  resultingStatus       String  @default("in_stock") @map("resulting_status")

  stockAdjustmentItem StockAdjustmentItem @relation(fields: [stockAdjustmentItemId], references: [id], onDelete: Restrict)
  serial              ProductSerial        @relation(fields: [serialId], references: [id], onDelete: Restrict)

  @@id([stockAdjustmentItemId, serialId])
  @@index([serialId])
  @@map("stock_adjustment_item_serials")
}

// ──────────────────────────────────────────────────────────────────────
// §5.6 Parties (customers, suppliers)
// ──────────────────────────────────────────────────────────────────────

model Customer {
  id                String   @id @default(uuid())
  companyId         String   @map("company_id")
  customerGroupId   String?  @map("customer_group_id")
  name              String
  phone             String?
  email             String?
  address           String?
  taxIdentifier     String?  @map("tax_identifier")
  creditLimit       Decimal  @default(0) @map("credit_limit")
  preferredBranchId String?  @map("preferred_branch_id")
  isActive          Boolean  @default(true) @map("is_active")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @default(now()) @map("updated_at")
  deletedAt         DateTime? @map("deleted_at")

  company        Company        @relation(fields: [companyId], references: [id], onDelete: Restrict)
  customerGroup  CustomerGroup? @relation(fields: [customerGroupId], references: [id])
  preferredBranch Branch?       @relation("CustomerPreferredBranch", fields: [preferredBranchId], references: [id])
  // M3 backward relations
  quotations      Quotation[]
  sales           Sale[]
  payments        Payment[]
  // M4 — accounting
  journalLines    JournalLine[]    @relation("JournalLineCustomer")
  // M5 — service
  serviceRequests ServiceRequest[]
  // M6 — CRM
  convertedLeads  Lead[]
  // Gap model backward relations
  advanceLedger   CustomerAdvanceLedger[]
  rewardPointTransactions RewardPointTransaction[] @relation("RewardPointCustomer")
  rewardPointConsumptions RewardPointConsumption[] @relation("RewardPointConsumptionCustomer")
  communicationConsents CommunicationConsent[] @relation("ConsentCustomer")
  campaignRecipients CommunicationCampaignRecipient[] @relation("CampaignRecipientCustomer")
  withholdingTransactions WithholdingTransaction[] @relation("WithholdingCustomer")
  dataSubjectRequests DataSubjectRequest[] @relation("DSRCustomer")

  @@index([companyId])
  @@index([customerGroupId])
  @@index([phone])
  @@index([email])
  @@index([preferredBranchId])
  @@index([isActive])
  @@index([deletedAt])
  @@map("customers")
}

model Supplier {
  id                String   @id @default(uuid())
  companyId         String   @map("company_id")
  name              String
  phone             String?
  email             String?
  address           String?
  taxIdentifier     String?  @map("tax_identifier")
  currencyCode      String   @default("BDT") @map("currency_code")
  paymentTermsDays  Int      @default(0) @map("payment_terms_days")
  isActive          Boolean  @default(true) @map("is_active")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @default(now()) @map("updated_at")
  deletedAt         DateTime? @map("deleted_at")

  company   Company  @relation(fields: [companyId], references: [id], onDelete: Restrict)
  currency  Currency @relation(fields: [currencyCode], references: [code])
  purchases Purchase[]
  purchaseReturns PurchaseReturn[]
  landedCostDocuments LandedCostDocument[]
  // M3 backward relations
  payments Payment[]
  // M4 — accounting
  journalLines    JournalLine[]    @relation("JournalLineSupplier")
  expenses        Expense[]        @relation("ExpenseSupplier")
  // Gap model backward relations
  advanceLedger   SupplierAdvanceLedger[]
  communicationConsents CommunicationConsent[] @relation("ConsentSupplier")
  withholdingTransactions WithholdingTransaction[] @relation("WithholdingSupplier")

  @@index([companyId])
  @@index([phone])
  @@index([email])
  @@index([currencyCode])
  @@index([isActive])
  @@index([deletedAt])
  @@map("suppliers")
}

// ──────────────────────────────────────────────────────────────────────
// §5.8 Purchasing and Supplier Returns
// ──────────────────────────────────────────────────────────────────────

model Purchase {
  id                String   @id @default(uuid())
  companyId         String   @map("company_id")
  branchId          String   @map("branch_id")
  warehouseId       String   @map("warehouse_id")
  referenceNo       String   @map("reference_no")
  supplierInvoiceNo String?  @map("supplier_invoice_no")
  supplierId        String   @map("supplier_id")
  orderStatus       String   @default("draft") @map("order_status")
  invoiceStatus     String   @default("not_invoiced") @map("invoice_status")
  currencyCode      String   @default("BDT") @map("currency_code")
  exchangeRate      Decimal  @default(1) @map("exchange_rate")
  orderDate         DateTime @map("order_date")
  expectedDate      DateTime? @map("expected_date")
  subtotal          Decimal  @default(0)
  discountTotal     Decimal  @default(0) @map("discount_total")
  taxTotal          Decimal  @default(0) @map("tax_total")
  landedCostTotal   Decimal  @default(0) @map("landed_cost_total")
  grandTotal        Decimal  @default(0) @map("grand_total")
  baseGrandTotal    Decimal  @default(0) @map("base_grand_total")
  notes             String?
  createdBy         String   @map("created_by")
  createdAt         DateTime @default(now()) @map("created_at")

  company    Company    @relation(fields: [companyId], references: [id], onDelete: Restrict)
  branch     Branch     @relation(fields: [branchId], references: [id])
  warehouse  Warehouse  @relation(fields: [warehouseId], references: [id])
  supplier   Supplier   @relation(fields: [supplierId], references: [id])
  currency   Currency   @relation(fields: [currencyCode], references: [code])
  items      PurchaseItem[]
  receivings PurchaseReceiving[]
  returns    PurchaseReturn[]
  landedCostDocuments LandedCostDocument[]
  // M3 backward relations
  paymentAllocations PaymentAllocation[]

  @@unique([companyId, referenceNo])
  @@index([companyId])
  @@index([branchId])
  @@index([warehouseId])
  @@index([supplierId])
  @@index([orderStatus])
  @@index([orderDate])
  @@map("purchases")
}

model PurchaseItem {
  id                          String   @id @default(uuid())
  companyId                   String   @map("company_id")
  purchaseId                  String   @map("purchase_id")
  lineNo                      Int      @map("line_no")
  productId                   String   @map("product_id")
  productNameSnapshot         String   @map("product_name_snapshot")
  productCodeSnapshot         String   @map("product_code_snapshot")
  qtyOrdered                  Decimal  @map("qty_ordered")
  qtyReceived                 Decimal  @default(0) @map("qty_received")
  qtyReturned                 Decimal  @default(0) @map("qty_returned")
  unitCost                    Decimal  @map("unit_cost")
  allocatedLandedCostPerUnit  Decimal  @default(0) @map("allocated_landed_cost_per_unit")
  discountAmount              Decimal  @default(0) @map("discount_amount")
  taxAmount                   Decimal  @default(0) @map("tax_amount")
  lineTotal                   Decimal  @default(0) @map("line_total")

  company    Company    @relation(fields: [companyId], references: [id], onDelete: Restrict)
  purchase   Purchase   @relation(fields: [purchaseId], references: [id])
  product    Product    @relation(fields: [productId], references: [id])
  taxes      PurchaseItemTax[]
  receivingItems PurchaseReceivingItem[]
  returnItems PurchaseReturnItem[]
  landedCostAllocations LandedCostAllocation[]
  originatingSerials ProductSerial[]

  @@unique([purchaseId, lineNo])
  @@index([companyId])
  @@index([purchaseId])
  @@index([productId])
  @@map("purchase_items")
}

model PurchaseItemTax {
  id                    String   @id @default(uuid())
  companyId             String   @map("company_id")
  purchaseItemId        String   @map("purchase_item_id")
  taxComponentId        String   @map("tax_component_id")
  componentCodeSnapshot String   @map("component_code_snapshot")
  rateSnapshot          Decimal  @map("rate_snapshot")
  taxableBase           Decimal  @map("taxable_base")
  taxAmount             Decimal  @map("tax_amount")
  recoverableAmount     Decimal  @default(0) @map("recoverable_amount")

  company        Company        @relation(fields: [companyId], references: [id], onDelete: Restrict)
  purchaseItem   PurchaseItem   @relation(fields: [purchaseItemId], references: [id])
  taxComponent   TaxComponent   @relation(fields: [taxComponentId], references: [id])

  @@unique([purchaseItemId, taxComponentId])
  @@index([companyId])
  @@index([purchaseItemId])
  @@index([taxComponentId])
  @@map("purchase_item_taxes")
}

model PurchaseReceiving {
  id                String   @id @default(uuid())
  companyId         String   @map("company_id")
  branchId          String   @map("branch_id")
  warehouseId       String   @map("warehouse_id")
  purchaseId        String   @map("purchase_id")
  referenceNo       String   @map("reference_no")
  clientTxnId       String   @map("client_txn_id")
  receivingStatus   String   @default("draft") @map("receiving_status")
  businessDate      DateTime @map("business_date")
  receivedAt        DateTime @default(now()) @map("received_at")
  supplierDocumentNo String? @map("supplier_document_no")
  notes             String?
  postedAt          DateTime? @map("posted_at")
  receivedBy        String   @map("received_by")
  createdAt         DateTime @default(now()) @map("created_at")

  company    Company    @relation(fields: [companyId], references: [id], onDelete: Restrict)
  branch     Branch     @relation(fields: [branchId], references: [id])
  warehouse  Warehouse  @relation(fields: [warehouseId], references: [id])
  purchase   Purchase   @relation(fields: [purchaseId], references: [id])
  items      PurchaseReceivingItem[]

  @@unique([companyId, referenceNo])
  @@unique([companyId, clientTxnId])
  @@index([companyId])
  @@index([branchId])
  @@index([warehouseId])
  @@index([purchaseId])
  @@index([receivingStatus])
  @@index([businessDate])
  @@map("purchase_receivings")
}

model PurchaseReceivingItem {
  id                        String   @id @default(uuid())
  companyId                 String   @map("company_id")
  purchaseReceivingId       String   @map("purchase_receiving_id")
  purchaseItemId            String   @map("purchase_item_id")
  lineNo                    Int      @map("line_no")
  qtyReceivedNow            Decimal  @map("qty_received_now")
  unitCostSnapshot          Decimal  @map("unit_cost_snapshot")
  landedCostPerUnitSnapshot Decimal  @default(0) @map("landed_cost_per_unit_snapshot")
  inventoryUnitCost         Decimal  @map("inventory_unit_cost")
  batchNo                   String?  @map("batch_no")
  manufacturedAt            DateTime? @map("manufactured_at")
  expiryDate                DateTime? @map("expiry_date")

  company      Company           @relation(fields: [companyId], references: [id], onDelete: Restrict)
  purchaseReceiving PurchaseReceiving @relation(fields: [purchaseReceivingId], references: [id])
  purchaseItem PurchaseItem      @relation(fields: [purchaseItemId], references: [id])
  serials      PurchaseReceivingItemSerial[]

  @@unique([purchaseReceivingId, lineNo])
  @@index([companyId])
  @@index([purchaseReceivingId])
  @@index([purchaseItemId])
  @@map("purchase_receiving_items")
}

model PurchaseReceivingItemSerial {
  purchaseReceivingItemId String  @map("purchase_receiving_item_id")
  serialId                String  @map("serial_id")

  purchaseReceivingItem PurchaseReceivingItem @relation(fields: [purchaseReceivingItemId], references: [id], onDelete: Restrict)
  serial                ProductSerial         @relation(fields: [serialId], references: [id], onDelete: Restrict)

  @@id([purchaseReceivingItemId, serialId])
  @@index([serialId])
  @@map("purchase_receiving_item_serials")
}

model LandedCostDocument {
  id                String   @id @default(uuid())
  companyId         String   @map("company_id")
  purchaseId        String   @map("purchase_id")
  referenceNo       String   @map("reference_no")
  costType          String   @default("freight") @map("cost_type") // freight/insurance/customs/port/clearing/other
  supplierId        String?  @map("supplier_id")
  currencyCode      String   @default("BDT") @map("currency_code")
  exchangeRate      Decimal  @default(1) @map("exchange_rate")
  amount            Decimal  @default(0)
  baseAmount        Decimal  @default(0) @map("base_amount")
  allocationMethod  String   @default("quantity") @map("allocation_method") // quantity/value/weight/manual
  status            String   @default("draft") // draft/posted/reversed
  createdBy         String   @map("created_by")
  createdAt         DateTime @default(now()) @map("created_at")

  company    Company    @relation(fields: [companyId], references: [id], onDelete: Restrict)
  purchase   Purchase   @relation(fields: [purchaseId], references: [id])
  supplier   Supplier?  @relation(fields: [supplierId], references: [id])
  currency   Currency   @relation(fields: [currencyCode], references: [code])
  allocations LandedCostAllocation[]

  @@unique([companyId, referenceNo])
  @@index([companyId])
  @@index([purchaseId])
  @@index([costType])
  @@index([supplierId])
  @@index([status])
  @@map("landed_cost_documents")
}

model LandedCostAllocation {
  landedCostDocumentId String  @map("landed_cost_document_id")
  purchaseItemId       String  @map("purchase_item_id")
  allocatedBaseAmount  Decimal @default(0) @map("allocated_base_amount")

  landedCostDocument LandedCostDocument @relation(fields: [landedCostDocumentId], references: [id], onDelete: Restrict)
  purchaseItem       PurchaseItem       @relation(fields: [purchaseItemId], references: [id], onDelete: Restrict)

  @@id([landedCostDocumentId, purchaseItemId])
  @@index([purchaseItemId])
  @@map("landed_cost_allocations")
}

model PurchaseReturn {
  id                String   @id @default(uuid())
  companyId         String   @map("company_id")
  branchId          String   @map("branch_id")
  warehouseId       String   @map("warehouse_id")
  purchaseId        String   @map("purchase_id")
  supplierId        String   @map("supplier_id")
  referenceNo       String   @map("reference_no")
  clientTxnId       String   @map("client_txn_id")
  status            String   @default("draft") // draft/approved/posted/voided
  businessDate      DateTime @map("business_date")
  supplierCreditNo  String?  @map("supplier_credit_no")
  reason            String
  subtotalCredit    Decimal  @default(0) @map("subtotal_credit")
  taxCredit         Decimal  @default(0) @map("tax_credit")
  totalCredit       Decimal  @default(0) @map("total_credit")
  baseTotalCredit   Decimal  @default(0) @map("base_total_credit")
  refundStatus      String   @default("not_required") @map("refund_status")
  approvedBy        String?  @map("approved_by")
  postedAt          DateTime? @map("posted_at")
  createdBy         String   @map("created_by")
  createdAt         DateTime @default(now()) @map("created_at")

  company    Company    @relation(fields: [companyId], references: [id], onDelete: Restrict)
  branch     Branch     @relation(fields: [branchId], references: [id])
  warehouse  Warehouse  @relation(fields: [warehouseId], references: [id])
  purchase   Purchase   @relation(fields: [purchaseId], references: [id])
  supplier   Supplier   @relation(fields: [supplierId], references: [id])
  items      PurchaseReturnItem[]
  // Gap model backward relations
  supplierAdvanceLedger SupplierAdvanceLedger[]

  @@unique([companyId, referenceNo])
  @@unique([companyId, clientTxnId])
  @@index([companyId])
  @@index([branchId])
  @@index([warehouseId])
  @@index([purchaseId])
  @@index([supplierId])
  @@index([status])
  @@index([businessDate])
  @@map("purchase_returns")
}

model PurchaseReturnItem {
  id                  String   @id @default(uuid())
  companyId           String   @map("company_id")
  purchaseReturnId    String   @map("purchase_return_id")
  purchaseItemId      String   @map("purchase_item_id")
  qtyReturned         Decimal  @map("qty_returned")
  supplierUnitCredit  Decimal  @map("supplier_unit_credit")
  inventoryUnitCost   Decimal  @map("inventory_unit_cost")
  taxCredit           Decimal  @default(0) @map("tax_credit")
  lineCredit          Decimal  @default(0) @map("line_credit")
  varianceAmount      Decimal  @default(0) @map("variance_amount")

  company        Company        @relation(fields: [companyId], references: [id], onDelete: Restrict)
  purchaseReturn PurchaseReturn @relation(fields: [purchaseReturnId], references: [id])
  purchaseItem   PurchaseItem   @relation(fields: [purchaseItemId], references: [id])
  serials        PurchaseReturnItemSerial[]

  @@index([companyId])
  @@index([purchaseReturnId])
  @@index([purchaseItemId])
  @@map("purchase_return_items")
}

model PurchaseReturnItemSerial {
  purchaseReturnItemId String  @map("purchase_return_item_id")
  serialId             String  @map("serial_id")

  purchaseReturnItem PurchaseReturnItem @relation(fields: [purchaseReturnItemId], references: [id], onDelete: Restrict)
  serial             ProductSerial       @relation(fields: [serialId], references: [id], onDelete: Restrict)

  @@id([purchaseReturnItemId, serialId])
  @@index([serialId])
  @@map("purchase_return_item_serials")
}

// ──────────────────────────────────────────────────────────────────────
// §5.9 Transfers
// ──────────────────────────────────────────────────────────────────────

model Transfer {
  id                String   @id @default(uuid())
  companyId         String   @map("company_id")
  referenceNo       String   @map("reference_no")
  clientTxnId       String   @map("client_txn_id")
  fromWarehouseId   String   @map("from_warehouse_id")
  toWarehouseId     String   @map("to_warehouse_id")
  status            String   @default("draft") // draft/pending/in_transit/completed/cancelled/returning/returned
  requestedBy       String   @map("requested_by")
  approvedBy        String?  @map("approved_by")
  dispatchedBy      String?  @map("dispatched_by")
  receivedBy        String?  @map("received_by")
  requestedAt       DateTime @default(now()) @map("requested_at")
  dispatchedAt      DateTime? @map("dispatched_at")
  receivedAt        DateTime? @map("received_at")
  cancellationReason String? @map("cancellation_reason")
  notes             String?

  company        Company   @relation(fields: [companyId], references: [id], onDelete: Restrict)
  fromWarehouse  Warehouse @relation("TransferFromWh", fields: [fromWarehouseId], references: [id])
  toWarehouse    Warehouse @relation("TransferToWh", fields: [toWarehouseId], references: [id])
  items          TransferItem[]

  @@unique([companyId, referenceNo])
  @@unique([companyId, clientTxnId])
  @@index([companyId])
  @@index([fromWarehouseId])
  @@index([toWarehouseId])
  @@index([status])
  @@index([dispatchedAt])
  @@index([receivedAt])
  @@map("transfers")
}

model TransferItem {
  id                String   @id @default(uuid())
  companyId         String   @map("company_id")
  transferId        String   @map("transfer_id")
  lineNo            Int      @map("line_no")
  productId         String   @map("product_id")
  qtyRequested      Decimal  @map("qty_requested")
  qtyDispatched     Decimal  @default(0) @map("qty_dispatched")
  qtyReceived       Decimal  @default(0) @map("qty_received")
  unitCostSnapshot  Decimal? @map("unit_cost_snapshot")
  reservationId     String?  @map("reservation_id")

  company     Company           @relation(fields: [companyId], references: [id], onDelete: Restrict)
  transfer    Transfer          @relation(fields: [transferId], references: [id])
  product     Product           @relation(fields: [productId], references: [id])
  reservation StockReservation? @relation(fields: [reservationId], references: [id])
  serials     TransferItemSerial[]

  @@unique([transferId, lineNo])
  @@index([companyId])
  @@index([transferId])
  @@index([productId])
  @@index([reservationId])
  @@map("transfer_items")
}

model TransferItemSerial {
  transferItemId String @map("transfer_item_id")
  serialId       String @map("serial_id")

  transferItem TransferItem  @relation(fields: [transferItemId], references: [id], onDelete: Restrict)
  serial       ProductSerial @relation(fields: [serialId], references: [id], onDelete: Restrict)

  @@id([transferItemId, serialId])
  @@index([serialId])
  @@map("transfer_item_serials")
}
// prisma/m3-additions.prisma
// M3 schema additions — §5.7 Sales + §5.11 Payments/Cashier Shifts
// Appended to schema.prisma.

// ──────────────────────────────────────────────────────────────────────
// §5.7 Quotations, Sales, Taxes, and Returns
// ──────────────────────────────────────────────────────────────────────

model Quotation {
  id                    String   @id @default(uuid())
  companyId             String   @map("company_id")
  branchId              String   @map("branch_id")
  referenceNo           String   @map("reference_no")
  clientTxnId           String   @map("client_txn_id")
  customerId            String?  @map("customer_id")
  customerNameSnapshot  String?  @map("customer_name_snapshot")
  currencyCode          String   @default("BDT") @map("currency_code")
  exchangeRate          Decimal  @default(1) @map("exchange_rate")
  status                String   @default("draft") // draft/sent/accepted/rejected/expired/converted
  validUntil            DateTime? @map("valid_until")
  businessDate          DateTime @map("business_date")
  subtotal              Decimal  @default(0)
  discountTotal         Decimal  @default(0) @map("discount_total")
  taxTotal              Decimal  @default(0) @map("tax_total")
  grandTotal            Decimal  @default(0) @map("grand_total")
  notes                 String?
  convertedSaleId       String?  @map("converted_sale_id")
  createdBy             String   @map("created_by")
  createdAt             DateTime @default(now()) @map("created_at")

  company    Company    @relation(fields: [companyId], references: [id], onDelete: Restrict)
  branch     Branch     @relation(fields: [branchId], references: [id])
  customer   Customer?  @relation(fields: [customerId], references: [id])
  currency   Currency   @relation(fields: [currencyCode], references: [code])
  convertedSale Sale?   @relation("QuotationConvertedSale")
  items      QuotationItem[]

  @@unique([companyId, referenceNo])
  @@unique([companyId, clientTxnId])
  @@index([companyId])
  @@index([branchId])
  @@index([customerId])
  @@index([status])
  @@index([businessDate])
  @@index([validUntil])
  @@map("quotations")
}

model QuotationItem {
  id                    String   @id @default(uuid())
  companyId             String   @map("company_id")
  quotationId           String   @map("quotation_id")
  lineNo                Int      @map("line_no")
  productId             String   @map("product_id")
  productNameSnapshot   String   @map("product_name_snapshot")
  productCodeSnapshot   String   @map("product_code_snapshot")
  qty                   Decimal
  unitPrice             Decimal  @map("unit_price")
  discountAmount        Decimal  @default(0) @map("discount_amount")
  taxAmount             Decimal  @default(0) @map("tax_amount")
  lineTotal             Decimal  @default(0) @map("line_total")

  company   Company   @relation(fields: [companyId], references: [id], onDelete: Restrict)
  quotation Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)
  product   Product   @relation(fields: [productId], references: [id])

  @@unique([quotationId, lineNo])
  @@index([companyId])
  @@index([quotationId])
  @@index([productId])
  @@map("quotation_items")
}

model Sale {
  id                    String   @id @default(uuid())
  companyId             String   @map("company_id")
  branchId              String   @map("branch_id")
  warehouseId           String   @map("warehouse_id")
  referenceNo           String   @map("reference_no")
  clientTxnId           String   @map("client_txn_id")
  quotationId           String?  @unique @map("quotation_id")
  customerId            String?  @map("customer_id")
  customerNameSnapshot  String?  @map("customer_name_snapshot")
  customerPhoneSnapshot String?  @map("customer_phone_snapshot")
  billerId              String   @map("biller_id")
  cashierShiftId        String?  @map("cashier_shift_id")
  saleStatus            String   @default("completed") @map("sale_status") // draft/held/completed/voided/partially_returned/returned
  currencyCode          String   @default("BDT") @map("currency_code")
  exchangeRate          Decimal  @default(1) @map("exchange_rate")
  subtotal              Decimal  @default(0)
  discountTotal         Decimal  @default(0) @map("discount_total")
  taxTotal              Decimal  @default(0) @map("tax_total")
  shippingTotal         Decimal  @default(0) @map("shipping_total")
  grandTotal            Decimal  @default(0) @map("grand_total")
  baseGrandTotal        Decimal  @default(0) @map("base_grand_total")
  saleNote              String?  @map("sale_note")
  businessDate          DateTime @map("business_date")
  offlineCreatedAt      DateTime? @map("offline_created_at")
  postedAt              DateTime? @map("posted_at")
  voidedAt              DateTime? @map("voided_at")
  voidedBy              String?  @map("voided_by")
  createdAt             DateTime @default(now()) @map("created_at")

  company        Company        @relation(fields: [companyId], references: [id], onDelete: Restrict)
  branch         Branch         @relation(fields: [branchId], references: [id])
  warehouse      Warehouse      @relation(fields: [warehouseId], references: [id])
  customer       Customer?      @relation(fields: [customerId], references: [id])
  currency       Currency       @relation(fields: [currencyCode], references: [code])
  biller         User           @relation("SaleBiller", fields: [billerId], references: [id])
  cashierShift   CashierShift?  @relation(fields: [cashierShiftId], references: [id])
  voidedByUser   User?          @relation("SaleVoidedBy", fields: [voidedBy], references: [id])
  convertedFromQuotation Quotation? @relation("QuotationConvertedSale", fields: [quotationId], references: [id])
  items          SaleItem[]
  returns        SaleReturn[]
  payments       PaymentAllocation[]
  installments   Installment[]
  // M5 — delivery + service
  deliveryOrders DeliveryOrder[]
  serviceRequestsSale ServiceRequest[]  @relation("ServiceRequestSale")
  serviceRequestsServiceSale ServiceRequest[]  @relation("ServiceRequestServiceSale")
  // Gap model backward relations
  couponRedemptions CouponRedemption[]
  rewardPointTransactions RewardPointTransaction[]

  @@unique([companyId, referenceNo])
  @@unique([companyId, clientTxnId])
  @@index([companyId])
  @@index([branchId])
  @@index([warehouseId])
  @@index([customerId])
  @@index([billerId])
  @@index([cashierShiftId])
  @@index([saleStatus])
  @@index([businessDate])
  @@index([postedAt])
  @@map("sales")
}

model SaleItem {
  id                    String   @id @default(uuid())
  companyId             String   @map("company_id")
  saleId                String   @map("sale_id")
  lineNo                Int      @map("line_no")
  productId             String   @map("product_id")
  productNameSnapshot   String   @map("product_name_snapshot")
  productCodeSnapshot   String   @map("product_code_snapshot")
  unitCodeSnapshot      String   @map("unit_code_snapshot")
  qty                   Decimal
  unitCostSnapshot      Decimal  @map("unit_cost_snapshot")
  unitPriceSnapshot     Decimal  @map("unit_price_snapshot")
  grossAmount           Decimal  @map("gross_amount")
  discountAmount        Decimal  @default(0) @map("discount_amount")
  taxableAmount         Decimal  @map("taxable_amount")
  taxAmount             Decimal  @default(0) @map("tax_amount")
  lineTotal             Decimal  @default(0) @map("line_total")
  warrantyMonthsSnapshot Int?   @map("warranty_months_snapshot")
  inventoryIssueSource  String   @default("sale") @map("inventory_issue_source") // sale/service_request/none

  company    Company    @relation(fields: [companyId], references: [id], onDelete: Restrict)
  sale       Sale       @relation(fields: [saleId], references: [id], onDelete: Restrict)
  product    Product    @relation(fields: [productId], references: [id])
  serials    SaleItemSerial[]
  taxes      SaleItemTax[]
  returnItems SaleReturnItem[]
  // M5 — delivery
  deliveryItems DeliveryItem[]

  @@unique([saleId, lineNo])
  @@index([companyId])
  @@index([saleId])
  @@index([productId])
  @@index([inventoryIssueSource])
  @@map("sale_items")
}

model SaleItemSerial {
  saleItemId String @map("sale_item_id")
  serialId   String @map("serial_id")

  saleItem SaleItem      @relation(fields: [saleItemId], references: [id], onDelete: Restrict)
  serial   ProductSerial @relation(fields: [serialId], references: [id], onDelete: Restrict)

  @@id([saleItemId, serialId])
  @@index([serialId])
  @@map("sale_item_serials")
}

model SaleItemTax {
  id                String   @id @default(uuid())
  companyId         String   @map("company_id")
  saleItemId        String   @map("sale_item_id")
  taxComponentId    String   @map("tax_component_id")
  componentCodeSnapshot String @map("component_code_snapshot")
  rateSnapshot      Decimal  @map("rate_snapshot")
  taxableBase       Decimal  @map("taxable_base")
  taxAmount         Decimal  @map("tax_amount")

  company       Company       @relation(fields: [companyId], references: [id], onDelete: Restrict)
  saleItem      SaleItem      @relation(fields: [saleItemId], references: [id])
  taxComponent  TaxComponent  @relation(fields: [taxComponentId], references: [id])

  @@unique([saleItemId, taxComponentId])
  @@index([companyId])
  @@index([saleItemId])
  @@index([taxComponentId])
  @@map("sale_item_taxes")
}

model SaleReturn {
  id                String   @id @default(uuid())
  companyId         String   @map("company_id")
  branchId          String   @map("branch_id")
  warehouseId       String   @map("warehouse_id")
  referenceNo       String   @map("reference_no")
  clientTxnId       String   @map("client_txn_id")
  saleId            String   @map("sale_id")
  status            String   @default("draft") // draft/approved/posted/voided
  businessDate      DateTime @map("business_date")
  disposition       String   @default("restock") // restock/damaged/repair/scrap/mixed
  reason            String
  subtotalCredit    Decimal  @default(0) @map("subtotal_credit")
  taxCredit         Decimal  @default(0) @map("tax_credit")
  totalCredit       Decimal  @default(0) @map("total_credit")
  baseTotalCredit   Decimal  @default(0) @map("base_total_credit")
  refundStatus      String   @default("not_required") @map("refund_status") // not_required/pending/partial/refunded
  approvedBy        String?  @map("approved_by")
  postedAt          DateTime? @map("posted_at")
  createdBy         String   @map("created_by")
  createdAt         DateTime @default(now()) @map("created_at")

  company    Company    @relation(fields: [companyId], references: [id], onDelete: Restrict)
  branch     Branch     @relation(fields: [branchId], references: [id])
  warehouse  Warehouse  @relation(fields: [warehouseId], references: [id])
  sale       Sale       @relation(fields: [saleId], references: [id])
  approver   User?      @relation("SaleReturnApprovedBy", fields: [approvedBy], references: [id])
  creator    User       @relation("SaleReturnCreatedBy", fields: [createdBy], references: [id])
  items      SaleReturnItem[]
  refundAllocations ReturnRefundAllocation[]
  refundPayments Payment[]
  // Gap model backward relations
  customerAdvanceLedger CustomerAdvanceLedger[]

  @@unique([companyId, referenceNo])
  @@unique([companyId, clientTxnId])
  @@index([companyId])
  @@index([saleId])
  @@index([status])
  @@index([businessDate])
  @@map("sale_returns")
}

model SaleReturnItem {
  id                String   @id @default(uuid())
  companyId         String   @map("company_id")
  saleReturnId      String   @map("sale_return_id")
  saleItemId        String   @map("sale_item_id")
  qtyReturned       Decimal  @map("qty_returned")
  unitPriceCredit   Decimal  @map("unit_price_credit")
  unitCostSnapshot  Decimal  @map("unit_cost_snapshot")
  discountCredit    Decimal  @default(0) @map("discount_credit")
  taxCredit         Decimal  @default(0) @map("tax_credit")
  lineCredit        Decimal  @default(0) @map("line_credit")
  condition         String   @default("resalable") // resalable/damaged/repair/scrap

  company     Company     @relation(fields: [companyId], references: [id], onDelete: Restrict)
  saleReturn  SaleReturn  @relation(fields: [saleReturnId], references: [id])
  saleItem    SaleItem    @relation(fields: [saleItemId], references: [id])
  serials     SaleReturnItemSerial[]

  @@index([companyId])
  @@index([saleReturnId])
  @@index([saleItemId])
  @@map("sale_return_items")
}

model SaleReturnItemSerial {
  saleReturnItemId String @map("sale_return_item_id")
  serialId         String @map("serial_id")

  saleReturnItem SaleReturnItem @relation(fields: [saleReturnItemId], references: [id], onDelete: Restrict)
  serial         ProductSerial   @relation(fields: [serialId], references: [id], onDelete: Restrict)

  @@id([saleReturnItemId, serialId])
  @@index([serialId])
  @@map("sale_return_item_serials")
}

// ──────────────────────────────────────────────────────────────────────
// §5.11 Payments, Cashier Shifts, Account Transfers
// ──────────────────────────────────────────────────────────────────────

model CashierShift {
  id                   String   @id @default(uuid())
  companyId            String   @map("company_id")
  branchId             String   @map("branch_id")
  warehouseId          String   @map("warehouse_id")
  cashierId            String   @map("cashier_id")
  cashAccountId        String   @map("cash_account_id")
  status               String   @default("open") // open/closing/closed/approved
  openedAt             DateTime @default(now()) @map("opened_at")
  closedAt             DateTime? @map("closed_at")
  openingFloat         Decimal  @default(0) @map("opening_float")
  expectedClosingCash  Decimal? @map("expected_closing_cash")
  countedClosingCash   Decimal? @map("counted_closing_cash")
  variance             Decimal?
  varianceReason       String?  @map("variance_reason")
  approvedBy           String?  @map("approved_by")
  approvedAt           DateTime? @map("approved_at")
  createdAt            DateTime @default(now()) @map("created_at")

  company     Company    @relation(fields: [companyId], references: [id], onDelete: Restrict)
  branch      Branch     @relation(fields: [branchId], references: [id])
  warehouse   Warehouse  @relation(fields: [warehouseId], references: [id])
  cashier     User       @relation("CashierShiftCashier", fields: [cashierId], references: [id])
  approver    User?      @relation("CashierShiftApprover", fields: [approvedBy], references: [id])
  cashAccount FinancialAccount @relation(fields: [cashAccountId], references: [id])
  sales       Sale[]
  payments    Payment[]
  drawerCounts CashDrawerCount[]

  @@index([companyId])
  @@index([branchId])
  @@index([cashierId])
  @@index([cashAccountId])
  @@index([status])
  @@index([openedAt])
  @@index([closedAt])
  @@map("cashier_shifts")
}

model CashDrawerCount {
  id                  String   @id @default(uuid())
  companyId           String   @map("company_id")
  cashierShiftId      String   @map("cashier_shift_id")
  countType           String   @default("opening") @map("count_type") // opening/spot/closing/recount
  countedAmount       Decimal  @default(0) @map("counted_amount")
  denominationDetail  String   @default("{}") @map("denomination_detail") // JSONB
  countedBy           String   @map("counted_by")
  countedAt           DateTime @default(now()) @map("counted_at")

  company       Company       @relation(fields: [companyId], references: [id], onDelete: Restrict)
  cashierShift  CashierShift  @relation(fields: [cashierShiftId], references: [id])
  counter       User          @relation("CashDrawerCountBy", fields: [countedBy], references: [id])

  @@index([companyId])
  @@index([cashierShiftId])
  @@index([countType])
  @@map("cash_drawer_counts")
}

model Payment {
  id                    String   @id @default(uuid())
  companyId             String   @map("company_id")
  branchId              String   @map("branch_id")
  referenceNo           String   @map("reference_no")
  clientTxnId           String   @map("client_txn_id")
  paymentType           String   @map("payment_type") // sale_receipt/purchase_payment/customer_advance/sale_refund/expense_payment/other
  direction             String   @default("incoming") // incoming/outgoing
  customerId            String?  @map("customer_id")
  supplierId            String?  @map("supplier_id")
  saleReturnId          String?  @map("sale_return_id")
  financialAccountId    String   @map("financial_account_id")
  cashierShiftId        String?  @map("cashier_shift_id")
  currencyCode          String   @default("BDT") @map("currency_code")
  exchangeRate          Decimal  @default(1) @map("exchange_rate")
  amount                Decimal  @default(0)
  baseAmount            Decimal  @default(0) @map("base_amount")
  paymentMethod         String   @default("cash") @map("payment_method") // cash/card/cheque/bkash/nagad/rocket/bank_transfer/gift_card/store_credit/other
  methodReference       String?  @map("method_reference")
  chequeStatus          String   @default("not_applicable") @map("cheque_status") // not_applicable/pending_clearance/cleared/bounced/cancelled
  paymentStatus         String   @default("posted") @map("payment_status") // pending/posted/failed/reversed
  businessDate          DateTime @map("business_date")
  receivedOrPaidAt      DateTime @default(now()) @map("received_or_paid_at")
  reversedPaymentId     String?  @map("reversed_payment_id")
  notes                 String?
  createdBy             String   @map("created_by")
  postedAt              DateTime? @map("posted_at")
  createdAt             DateTime @default(now()) @map("created_at")

  company          Company       @relation(fields: [companyId], references: [id], onDelete: Restrict)
  branch           Branch        @relation(fields: [branchId], references: [id])
  customer         Customer?     @relation(fields: [customerId], references: [id])
  supplier         Supplier?     @relation(fields: [supplierId], references: [id])
  saleReturn       SaleReturn?   @relation(fields: [saleReturnId], references: [id])
  cashierShift     CashierShift? @relation(fields: [cashierShiftId], references: [id])
  financialAccount FinancialAccount @relation(fields: [financialAccountId], references: [id])
  currency         Currency      @relation(fields: [currencyCode], references: [code])
  reversedPayment  Payment?      @relation("PaymentReversal", fields: [reversedPaymentId], references: [id])
  reversingPayment Payment[]     @relation("PaymentReversal")
  allocations      PaymentAllocation[]
  refundAllocations ReturnRefundAllocation[]
  creator          User          @relation("PaymentCreatedBy", fields: [createdBy], references: [id])
  // Gap model backward relations
  customerAdvanceLedger CustomerAdvanceLedger[]
  supplierAdvanceLedger SupplierAdvanceLedger[] @relation("SupplierAdvancePayment")
  withholdingTransactions WithholdingTransaction[]

  @@unique([companyId, referenceNo])
  @@unique([companyId, clientTxnId])
  @@index([companyId])
  @@index([branchId])
  @@index([customerId])
  @@index([supplierId])
  @@index([saleReturnId])
  @@index([cashierShiftId])
  @@index([paymentType])
  @@index([direction])
  @@index([paymentMethod])
  @@index([chequeStatus])
  @@index([paymentStatus])
  @@index([businessDate])
  @@map("payments")
}

model PaymentAllocation {
  id                  String   @id @default(uuid())
  companyId           String   @map("company_id")
  paymentId           String   @map("payment_id")
  eventId             String   @map("event_id")
  eventLineNo         Int      @map("event_line_no")
  saleId              String?  @map("sale_id")
  purchaseId          String?  @map("purchase_id")
  allocationSource    String   @default("direct") @map("allocation_source") // direct/advance/store_credit/courier_cod
  allocatedAmount     Decimal  @map("allocated_amount")
  allocatedBaseAmount Decimal  @map("allocated_base_amount")
  allocatedAt         DateTime @default(now()) @map("allocated_at")
  createdBy           String   @map("created_by")

  company      Company      @relation(fields: [companyId], references: [id], onDelete: Restrict)
  payment      Payment      @relation(fields: [paymentId], references: [id])
  businessEvent BusinessEvent @relation(fields: [eventId], references: [id])
  sale         Sale?        @relation(fields: [saleId], references: [id])
  purchase     Purchase?    @relation(fields: [purchaseId], references: [id])
  creator      User         @relation("PaymentAllocCreatedBy", fields: [createdBy], references: [id])
  installments InstallmentAllocation[]

  @@unique([companyId, eventId, eventLineNo])
  @@index([companyId])
  @@index([paymentId])
  @@index([eventId])
  @@index([saleId])
  @@index([purchaseId])
  @@index([allocationSource])
  @@map("payment_allocations")
}

model ReturnRefundAllocation {
  id                  String   @id @default(uuid())
  companyId           String   @map("company_id")
  paymentId           String   @map("payment_id")
  saleReturnId        String?  @map("sale_return_id")
  purchaseReturnId    String?  @map("purchase_return_id")
  allocatedAmount     Decimal  @map("allocated_amount")
  allocatedBaseAmount Decimal  @map("allocated_base_amount")

  company      Company      @relation(fields: [companyId], references: [id], onDelete: Restrict)
  payment      Payment      @relation(fields: [paymentId], references: [id])
  saleReturn   SaleReturn?  @relation(fields: [saleReturnId], references: [id])

  @@unique([paymentId])
  @@index([companyId])
  @@index([paymentId])
  @@index([saleReturnId])
  @@index([purchaseReturnId])
  @@map("return_refund_allocations")
}

model Installment {
  id          String   @id @default(uuid())
  companyId   String   @map("company_id")
  saleId      String   @map("sale_id")
  installmentNo Int    @map("installment_no")
  dueDate     DateTime @map("due_date")
  amount      Decimal
  status      String   @default("scheduled") // scheduled/cancelled

  company Company    @relation(fields: [companyId], references: [id], onDelete: Restrict)
  sale    Sale       @relation(fields: [saleId], references: [id])
  allocations InstallmentAllocation[]

  @@unique([saleId, installmentNo])
  @@index([companyId])
  @@index([saleId])
  @@index([dueDate])
  @@index([status])
  @@map("installments")
}

model InstallmentAllocation {
  id                  String   @id @default(uuid())
  companyId           String   @map("company_id")
  installmentId       String   @map("installment_id")
  paymentAllocationId String   @unique @map("payment_allocation_id")
  allocatedAmount     Decimal  @map("allocated_amount")
  allocatedAt         DateTime @default(now()) @map("allocated_at")

  company           Company           @relation(fields: [companyId], references: [id], onDelete: Restrict)
  installment       Installment       @relation(fields: [installmentId], references: [id])
  paymentAllocation PaymentAllocation @relation(fields: [paymentAllocationId], references: [id])

  @@index([companyId])
  @@index([installmentId])
  @@map("installment_allocations")
}
// prisma/m4-financial-additions.prisma
// M4 financial models needed early for M3 (financial_accounts referenced by payments).
// Full M4 schema (journal_entries, fiscal_periods, accounting_policies, expenses) added later.

model ChartOfAccount {
  id                  String   @id @default(uuid())
  companyId           String   @map("company_id")
  code                String
  name                String
  accountClass        String   @default("asset") @map("account_class") // asset/liability/equity/revenue/expense
  accountSubtype      String   @map("account_subtype")
  parentId            String?  @map("parent_id")
  normalBalance       String   @default("D") @map("normal_balance") // D/C
  allowManualPosting  Boolean  @default(false) @map("allow_manual_posting")
  isControlAccount    Boolean  @default(false) @map("is_control_account")
  isActive            Boolean  @default(true) @map("is_active")

  company  Company          @relation(fields: [companyId], references: [id], onDelete: Restrict)
  parent   ChartOfAccount?  @relation("CoaTree", fields: [parentId], references: [id])
  children ChartOfAccount[] @relation("CoaTree")
  financialAccounts FinancialAccount[]
  taxComponentInputs   TaxComponent[] @relation("TaxCompInputAccount")
  taxComponentOutputs  TaxComponent[] @relation("TaxCompOutputAccount")
  // M4 — accounting
  journalLines        JournalLine[]
  // Accounting policy relations (each policy references 9+ accounts)
  policyInventory     AccountingPolicy[] @relation("PolInventory")
  policyCogs          AccountingPolicy[] @relation("PolCOGS")
  policyRevenue       AccountingPolicy[] @relation("PolRevenue")
  policyAR            AccountingPolicy[] @relation("PolAR")
  policyAP            AccountingPolicy[] @relation("PolAP")
  policyCustAdv       AccountingPolicy[] @relation("PolCustAdv")
  policySupAdv        AccountingPolicy[] @relation("PolSupAdv")
  policyPurchVar      AccountingPolicy[] @relation("PolPurchVar")
  policyGiftCard      AccountingPolicy[] @relation("PolGiftCard")
  // Expense category
  expenseCategories   ExpenseCategory[]  @relation("ExpCatAccount")
  // Gap model backward relations
  payrollComponents   PayrollComponent[] @relation("PayrollCompAccount")

  @@unique([companyId, code])
  @@index([companyId])
  @@index([accountClass])
  @@index([accountSubtype])
  @@index([parentId])
  @@index([isControlAccount])
  @@map("chart_of_accounts")
}

model FinancialAccount {
  id                       String   @id @default(uuid())
  companyId                String   @map("company_id")
  branchId                 String?  @map("branch_id")
  chartOfAccountId         String   @map("chart_of_account_id")
  name                     String
  accountType              String   @default("cash") @map("account_type") // cash/bank/mobile_wallet/clearing
  currencyCode             String   @default("BDT") @map("currency_code")
  accountNumberMasked      String?  @map("account_number_masked")
  accountNumberEncrypted   Bytes?   @map("account_number_encrypted")
  accountNumberKeyVersion  Int      @default(1) @map("account_number_key_version")
  isActive                 Boolean  @default(true) @map("is_active")

  company        Company        @relation(fields: [companyId], references: [id], onDelete: Restrict)
  branch         Branch?        @relation(fields: [branchId], references: [id])
  chartOfAccount ChartOfAccount @relation(fields: [chartOfAccountId], references: [id])
  currency       Currency       @relation(fields: [currencyCode], references: [code])
  payments       Payment[]
  cashierShifts  CashierShift[]
  // M4 — accounting
  journalLines   JournalLine[]
  // M5 — COD settlements
  codSettlements CourierCodSettlement[]
  // Gap model backward relations
  accountTransfersFrom AccountTransfer[] @relation("TransferFromFA")
  accountTransfersTo   AccountTransfer[] @relation("TransferToFA")
  // AM-BR — bank reconciliations
  bankReconciliations  BankReconciliation[]

  @@unique([companyId, chartOfAccountId])
  @@index([companyId])
  @@index([branchId])
  @@index([accountType])
  @@map("financial_accounts")
}
// prisma/m4-additions.prisma
// M4 schema — §5.10 Accounting (fiscal_periods, journal_entries, journal_lines,
// accounting_policies) + §5.12 Expenses (expense_categories, expenses, expense_items,
// expense_item_taxes, expense_attachments).

model FiscalPeriod {
  id          String   @id @default(uuid())
  companyId   String   @map("company_id")
  periodName  String   @map("period_name")
  periodStart DateTime @map("period_start")
  periodEnd   DateTime @map("period_end")
  status      String   @default("open") // open/soft_locked/locked
  lockedBy    String?  @map("locked_by")
  lockedAt    DateTime? @map("locked_at")

  company Company @relation(fields: [companyId], references: [id], onDelete: Restrict)
  locker  User?   @relation("FiscalPeriodLockedBy", fields: [lockedBy], references: [id])

  @@unique([companyId, periodName])
  @@index([companyId])
  @@index([status])
  @@index([periodStart])
  @@index([periodEnd])
  @@map("fiscal_periods")
}

model JournalEntry {
  id                String   @id @default(uuid())
  companyId         String   @map("company_id")
  entryNo           String   @map("entry_no")
  eventId           String   @map("event_id")
  postingKind       String   @map("posting_kind")
  entryDate         DateTime @map("entry_date")
  postingDate       DateTime @default(now()) @map("posting_date")
  sourceType        String   @map("source_type")
  sourceId          String   @map("source_id")
  currencyCode      String   @default("BDT") @map("currency_code")
  exchangeRate      Decimal  @default(1) @map("exchange_rate")
  description       String
  status            String   @default("posted") // draft/posted/reversed
  reversalOfEntryId String?  @map("reversal_of_entry_id")
  createdBy         String   @map("created_by")
  postedBy          String?  @map("posted_by")
  postedAt          DateTime? @map("posted_at")
  createdAt         DateTime @default(now()) @map("created_at")

  company       Company        @relation(fields: [companyId], references: [id], onDelete: Restrict)
  businessEvent BusinessEvent  @relation("JournalEntryEvent", fields: [eventId], references: [id])
  currency      Currency       @relation("JournalEntryCurrency", fields: [currencyCode], references: [code])
  reversalOf    JournalEntry?  @relation("JournalEntryReversal", fields: [reversalOfEntryId], references: [id])
  reversedBy    JournalEntry[] @relation("JournalEntryReversal")
  lines         JournalLine[]
  // M4 — expense
  expenses      Expense[]      @relation("ExpenseJournalEntry")
  // M5 — COD settlement
  codSettlements CourierCodSettlement[] @relation("CodSettlementJournal")
  // Gap model backward relations
  accountTransfers AccountTransfer[]   @relation("TransferJournalEntry")
  creator       User           @relation("JournalEntryCreatedBy", fields: [createdBy], references: [id])
  poster        User?          @relation("JournalEntryPostedBy", fields: [postedBy], references: [id])

  @@unique([companyId, entryNo])
  @@unique([companyId, eventId, postingKind])
  @@index([companyId])
  @@index([entryDate])
  @@index([postingDate])
  @@index([sourceType, sourceId])
  @@index([status])
  @@index([postedAt])
  @@map("journal_entries")
}

model JournalLine {
  id                  String   @id @default(uuid())
  companyId           String   @map("company_id")
  journalEntryId      String   @map("journal_entry_id")
  lineNo              Int      @map("line_no")
  branchId            String?  @map("branch_id")
  chartOfAccountId    String   @map("chart_of_account_id")
  financialAccountId  String?  @map("financial_account_id")
  customerId          String?  @map("customer_id")
  supplierId          String?  @map("supplier_id")
  productId           String?  @map("product_id")
  debitBase           Decimal  @default(0) @map("debit_base")
  creditBase          Decimal  @default(0) @map("credit_base")
  amountCurrency      Decimal? @map("amount_currency")
  currencyCode        String?  @map("currency_code")
  memo                String?

  company        Company        @relation(fields: [companyId], references: [id], onDelete: Restrict)
  journalEntry   JournalEntry   @relation(fields: [journalEntryId], references: [id], onDelete: Restrict)
  branch         Branch?        @relation("JournalLineBranch", fields: [branchId], references: [id])
  chartOfAccount ChartOfAccount @relation(fields: [chartOfAccountId], references: [id])
  financialAccount FinancialAccount? @relation(fields: [financialAccountId], references: [id])
  customer       Customer?      @relation("JournalLineCustomer", fields: [customerId], references: [id])
  supplier       Supplier?      @relation("JournalLineSupplier", fields: [supplierId], references: [id])
  product        Product?       @relation("JournalLineProduct", fields: [productId], references: [id])
  currency       Currency?      @relation("JournalLineCurrency", fields: [currencyCode], references: [code])

  @@unique([journalEntryId, lineNo])
  @@index([companyId])
  @@index([journalEntryId])
  @@index([branchId])
  @@index([chartOfAccountId])
  @@index([financialAccountId])
  @@index([customerId])
  @@index([supplierId])
  @@index([productId])
  @@map("journal_lines")
}

model AccountingPolicy {
  id                          String  @id @default(uuid())
  companyId                   String  @map("company_id") @unique
  inventoryAccountId          String  @map("inventory_account_id")
  cogsAccountId               String  @map("cogs_account_id")
  salesRevenueAccountId       String  @map("sales_revenue_account_id")
  arAccountId                 String  @map("ar_account_id")
  apAccountId                 String  @map("ap_account_id")
  customerAdvanceAccountId    String  @map("customer_advance_account_id")
  supplierAdvanceAccountId    String  @map("supplier_advance_account_id")
  purchaseVarianceAccountId   String  @map("purchase_variance_account_id")
  giftCardLiabilityAccountId  String  @map("gift_card_liability_account_id")
  rewardExpenseAccountId      String? @map("reward_expense_account_id")
  branchClearingAccountId     String? @map("branch_clearing_account_id")
  inventoryDamageAccountId    String? @map("inventory_damage_account_id")
  inventoryWriteOffAccountId  String? @map("inventory_write_off_account_id")
  exchangeGainLossAccountId   String? @map("exchange_gain_loss_account_id")
  courierClearingAccountId    String? @map("courier_clearing_account_id")
  serviceCogsAccountId        String? @map("service_cogs_account_id")
  repairWipAccountId          String? @map("repair_wip_account_id")
  chequeClearingAccountId     String? @map("cheque_clearing_account_id")
  roundingAccountId           String? @map("rounding_account_id")
  grniAccountId               String? @map("grni_account_id")
  openingBalanceEquityAccountId String? @map("opening_balance_equity_account_id")
  impairmentAllowanceAccountId String? @map("impairment_allowance_account_id")
  chequeBounceFeeAccountId    String? @map("cheque_bounce_fee_account_id")

  company Company @relation(fields: [companyId], references: [id], onDelete: Restrict)
  inventoryAccount          ChartOfAccount @relation("PolInventory", fields: [inventoryAccountId], references: [id])
  cogsAccount               ChartOfAccount @relation("PolCOGS", fields: [cogsAccountId], references: [id])
  salesRevenueAccount       ChartOfAccount @relation("PolRevenue", fields: [salesRevenueAccountId], references: [id])
  arAccount                 ChartOfAccount @relation("PolAR", fields: [arAccountId], references: [id])
  apAccount                 ChartOfAccount @relation("PolAP", fields: [apAccountId], references: [id])
  customerAdvanceAccount    ChartOfAccount @relation("PolCustAdv", fields: [customerAdvanceAccountId], references: [id])
  supplierAdvanceAccount    ChartOfAccount @relation("PolSupAdv", fields: [supplierAdvanceAccountId], references: [id])
  purchaseVarianceAccount   ChartOfAccount @relation("PolPurchVar", fields: [purchaseVarianceAccountId], references: [id])
  giftCardLiabilityAccount  ChartOfAccount @relation("PolGiftCard", fields: [giftCardLiabilityAccountId], references: [id])

  @@map("accounting_policies")
}

model ExpenseCategory {
  id                String  @id @default(uuid())
  companyId         String  @map("company_id")
  name              String
  expenseAccountId  String  @map("expense_account_id")
  requiresApproval  Boolean @default(true) @map("requires_approval")
  isActive          Boolean @default(true) @map("is_active")

  company Company @relation(fields: [companyId], references: [id], onDelete: Restrict)
  expenseAccount ChartOfAccount @relation("ExpCatAccount", fields: [expenseAccountId], references: [id])
  // M4 — expense items
  expenseItems   ExpenseItem[]

  @@unique([companyId, name])
  @@index([companyId])
  @@map("expense_categories")
}

model Expense {
  id                String   @id @default(uuid())
  companyId         String   @map("company_id")
  branchId          String   @map("branch_id")
  referenceNo       String   @map("reference_no")
  clientTxnId       String   @map("client_txn_id")
  supplierId        String?  @map("supplier_id")
  payeeName         String?  @map("payee_name")
  status            String   @default("draft") // draft/pending_approval/approved/posted/rejected/voided
  expenseDate       DateTime @map("expense_date")
  currencyCode      String   @default("BDT") @map("currency_code")
  exchangeRate      Decimal  @default(1) @map("exchange_rate")
  subtotal          Decimal  @default(0)
  taxTotal          Decimal  @default(0) @map("tax_total")
  grandTotal        Decimal  @default(0) @map("grand_total")
  baseGrandTotal    Decimal  @default(0) @map("base_grand_total")
  description       String
  requestedBy       String   @map("requested_by")
  approvedBy        String?  @map("approved_by")
  approvalRequestId String?  @map("approval_request_id")
  journalEntryId    String?  @map("journal_entry_id")
  postedAt          DateTime? @map("posted_at")
  createdAt         DateTime @default(now()) @map("created_at")

  company    Company    @relation(fields: [companyId], references: [id], onDelete: Restrict)
  branch     Branch     @relation("ExpenseBranch", fields: [branchId], references: [id])
  supplier   Supplier?  @relation("ExpenseSupplier", fields: [supplierId], references: [id])
  currency   Currency   @relation("ExpenseCurrency", fields: [currencyCode], references: [code])
  requester  User       @relation("ExpenseRequestedBy", fields: [requestedBy], references: [id])
  approver   User?      @relation("ExpenseApprovedBy", fields: [approvedBy], references: [id])
  journalEntry JournalEntry? @relation("ExpenseJournalEntry", fields: [journalEntryId], references: [id])
  items      ExpenseItem[]
  // Gap model backward relations
  attachments ExpenseAttachment[]

  @@unique([companyId, referenceNo])
  @@unique([companyId, clientTxnId])
  @@index([companyId])
  @@index([branchId])
  @@index([supplierId])
  @@index([status])
  @@index([expenseDate])
  @@map("expenses")
}

model ExpenseItem {
  id                  String   @id @default(uuid())
  companyId           String   @map("company_id")
  expenseId           String   @map("expense_id")
  lineNo              Int      @map("line_no")
  expenseCategoryId   String   @map("expense_category_id")
  description         String
  amount              Decimal  @default(0)
  taxAmount           Decimal  @default(0) @map("tax_amount")
  baseAmount          Decimal  @default(0) @map("base_amount")

  company       Company         @relation(fields: [companyId], references: [id], onDelete: Restrict)
  expense       Expense         @relation(fields: [expenseId], references: [id], onDelete: Restrict)
  expenseCategory ExpenseCategory @relation(fields: [expenseCategoryId], references: [id])
  // Gap model backward relations
  taxes ExpenseItemTax[]

  @@unique([expenseId, lineNo])
  @@index([companyId])
  @@index([expenseId])
  @@index([expenseCategoryId])
  @@map("expense_items")
}
// prisma/m5-additions.prisma
// M5 — §5.7A Delivery, Courier, Service, and Warranty

// Delivery
model DeliveryOrder {
  id                  String   @id @default(uuid())
  companyId           String   @map("company_id")
  branchId            String   @map("branch_id")
  saleId              String   @map("sale_id")
  referenceNo         String   @map("reference_no")
  status              String   @default("pending") // pending/packing/ready/dispatched/in_transit/delivered/failed/returned/cancelled
  recipientName       String   @map("recipient_name")
  recipientPhone      String   @map("recipient_phone")
  addressSnapshot     String   @map("address_snapshot")
  district            String?
  area                String?
  deliveryMethod      String   @default("internal") @map("delivery_method") // internal/courier/pickup
  courierCode         String?  @map("courier_code")
  codAmount           Decimal  @default(0) @map("cod_amount")
  deliveryFee         Decimal  @default(0) @map("delivery_fee")
  expectedDeliveryDate DateTime? @map("expected_delivery_date")
  deliveredAt         DateTime? @map("delivered_at")
  receivedByName      String?  @map("received_by_name")
  assignedUserId      String?  @map("assigned_user_id")
  createdBy           String   @map("created_by")
  createdAt           DateTime @default(now()) @map("created_at")

  company    Company    @relation(fields: [companyId], references: [id], onDelete: Restrict)
  branch     Branch     @relation(fields: [branchId], references: [id])
  sale       Sale       @relation(fields: [saleId], references: [id])
  assignedUser User?   @relation("DeliveryAssignedTo", fields: [assignedUserId], references: [id])
  creator    User       @relation("DeliveryCreatedBy", fields: [createdBy], references: [id])
  items      DeliveryItem[]
  events     DeliveryEvent[]
  shipment   CourierShipment?
  codSettlementItems CourierCodSettlementItem[]

  @@unique([companyId, referenceNo])
  @@index([companyId])
  @@index([saleId])
  @@index([status])
  @@index([deliveryMethod])
  @@index([courierCode])
  @@index([recipientPhone])
  @@index([createdAt])
  @@map("delivery_orders")
}

model DeliveryItem {
  id              String   @id @default(uuid())
  companyId       String   @map("company_id")
  deliveryOrderId String   @map("delivery_order_id")
  saleItemId      String   @map("sale_item_id")
  quantity        Decimal

  company       Company       @relation(fields: [companyId], references: [id], onDelete: Restrict)
  deliveryOrder DeliveryOrder @relation(fields: [deliveryOrderId], references: [id])
  saleItem      SaleItem      @relation(fields: [saleItemId], references: [id])

  @@unique([deliveryOrderId, saleItemId])
  @@index([companyId])
  @@index([deliveryOrderId])
  @@index([saleItemId])
  @@map("delivery_items")
}

model DeliveryEvent {
  id              String   @id @default(uuid())
  companyId       String   @map("company_id")
  deliveryOrderId String   @map("delivery_order_id")
  fromStatus      String?  @map("from_status")
  toStatus        String   @map("to_status")
  eventAt         DateTime @default(now()) @map("event_at")
  providerStatus  String?  @map("provider_status")
  locationText    String?  @map("location_text")
  note            String?
  createdBy       String?  @map("created_by")

  company       Company       @relation(fields: [companyId], references: [id], onDelete: Restrict)
  deliveryOrder DeliveryOrder @relation(fields: [deliveryOrderId], references: [id])
  creator       User?         @relation("DeliveryEventCreatedBy", fields: [createdBy], references: [id])

  @@index([companyId])
  @@index([deliveryOrderId])
  @@index([toStatus])
  @@index([eventAt])
  @@map("delivery_events")
}

model CourierShipment {
  id                     String   @id @default(uuid())
  companyId              String   @map("company_id")
  deliveryOrderId        String   @unique @map("delivery_order_id")
  integrationCredentialId String  @map("integration_credential_id")
  providerShipmentId     String?  @map("provider_shipment_id")
  trackingCode           String?  @map("tracking_code")
  bookingStatus          String   @default("pending") @map("booking_status") // pending/booked/failed/cancelled
  labelMediaId           String?  @map("label_media_id")
  quotedCharge           Decimal? @map("quoted_charge")
  finalCharge            Decimal? @map("final_charge")
  lastProviderStatus     String?  @map("last_provider_status")
  lastSyncedAt           DateTime? @map("last_synced_at")
  sanitizedProviderData  String   @default("{}") @map("sanitized_provider_data")

  company        Company        @relation(fields: [companyId], references: [id], onDelete: Restrict)
  deliveryOrder  DeliveryOrder  @relation(fields: [deliveryOrderId], references: [id])

  @@index([companyId])
  @@index([bookingStatus])
  @@index([trackingCode])
  @@map("courier_shipments")
}

model CourierCodSettlement {
  id                  String   @id @default(uuid())
  companyId           String   @map("company_id")
  branchId            String   @map("branch_id")
  referenceNo         String   @map("reference_no")
  courierCode         String   @map("courier_code")
  settlementDate      DateTime @map("settlement_date")
  grossCodAmount      Decimal  @default(0) @map("gross_cod_amount")
  feeAmount           Decimal  @default(0) @map("fee_amount")
  adjustmentAmount    Decimal  @default(0) @map("adjustment_amount")
  netReceivedAmount   Decimal  @default(0) @map("net_received_amount")
  status              String   @default("draft") // draft/reconciled/posted/reversed
  financialAccountId  String   @map("financial_account_id")
  journalEntryId      String?  @map("journal_entry_id")
  createdBy           String   @map("created_by")
  postedAt            DateTime? @map("posted_at")

  company          Company          @relation(fields: [companyId], references: [id], onDelete: Restrict)
  branch           Branch           @relation(fields: [branchId], references: [id])
  financialAccount FinancialAccount @relation(fields: [financialAccountId], references: [id])
  journalEntry     JournalEntry?    @relation("CodSettlementJournal", fields: [journalEntryId], references: [id])
  creator          User             @relation("CodSettlementCreatedBy", fields: [createdBy], references: [id])
  items            CourierCodSettlementItem[]

  @@unique([companyId, referenceNo])
  @@index([companyId])
  @@index([courierCode])
  @@index([status])
  @@index([settlementDate])
  @@map("courier_cod_settlements")
}

model CourierCodSettlementItem {
  settlementId      String  @map("settlement_id")
  deliveryOrderId   String  @map("delivery_order_id")
  codAmount         Decimal @default(0) @map("cod_amount")
  feeAmount         Decimal @default(0) @map("fee_amount")
  adjustmentAmount  Decimal @default(0) @map("adjustment_amount")

  settlement     CourierCodSettlement @relation(fields: [settlementId], references: [id], onDelete: Restrict)
  deliveryOrder  DeliveryOrder        @relation(fields: [deliveryOrderId], references: [id], onDelete: Restrict)

  @@id([settlementId, deliveryOrderId])
  @@unique([deliveryOrderId])
  @@map("courier_cod_settlement_items")
}

// Service
model ServiceRequest {
  id                       String   @id @default(uuid())
  companyId                String   @map("company_id")
  branchId                 String   @map("branch_id")
  repairWarehouseId        String?  @map("repair_warehouse_id")
  referenceNo              String   @map("reference_no")
  customerId               String?  @map("customer_id")
  saleId                   String?  @map("sale_id")
  serviceSaleId            String?  @unique @map("service_sale_id")
  serialId                 String?  @map("serial_id")
  serviceType              String   @default("paid_repair") @map("service_type") // warranty/paid_repair/installation/inspection
  status                   String   @default("received") // received/diagnosing/awaiting_customer_approval/approved/in_repair/awaiting_parts/ready/delivered/unrepairable/cancelled
  issueDescription         String   @map("issue_description")
  intakeCondition          String?  @map("intake_condition")
  accessoriesReceived      String?  @map("accessories_received")
  estimatedAmount          Decimal  @default(0) @map("estimated_amount")
  approvedAmount           Decimal? @map("approved_amount")
  depositRequiredAmount    Decimal  @default(0) @map("deposit_required_amount")
  promisedDate             DateTime? @map("promised_date")
  warrantyEligibleSnapshot Boolean? @map("warranty_eligible_snapshot")
  warrantyExpirySnapshot   DateTime? @map("warranty_expiry_snapshot")
  createdBy                String   @map("created_by")
  receivedAt               DateTime @default(now()) @map("received_at")
  deliveredAt              DateTime? @map("delivered_at")

  company       Company        @relation(fields: [companyId], references: [id], onDelete: Restrict)
  branch        Branch         @relation(fields: [branchId], references: [id])
  repairWarehouse Warehouse?  @relation(fields: [repairWarehouseId], references: [id])
  customer      Customer?      @relation(fields: [customerId], references: [id])
  sale          Sale?          @relation("ServiceRequestSale", fields: [saleId], references: [id])
  serviceSale   Sale?          @relation("ServiceRequestServiceSale", fields: [serviceSaleId], references: [id])
  serial        ProductSerial? @relation(fields: [serialId], references: [id])
  creator       User           @relation("ServiceRequestCreatedBy", fields: [createdBy], references: [id])
  parts         ServiceRequestPart[]
  events        ServiceEvent[]
  warrantyClaim WarrantyClaim?

  @@unique([companyId, referenceNo])
  @@index([companyId])
  @@index([branchId])
  @@index([customerId])
  @@index([saleId])
  @@index([serialId])
  @@index([serviceType])
  @@index([status])
  @@index([receivedAt])
  @@map("service_requests")
}

model ServiceRequestPart {
  id                String   @id @default(uuid())
  companyId         String   @map("company_id")
  serviceRequestId  String   @map("service_request_id")
  lineNo            Int      @map("line_no")
  productId         String   @map("product_id")
  quantity          Decimal
  unitCostSnapshot  Decimal  @map("unit_cost_snapshot")
  unitPrice         Decimal  @map("unit_price")
  warrantyCovered   Boolean  @default(false) @map("warranty_covered")
  consumedEventId   String?  @map("consumed_event_id")

  company        Company        @relation(fields: [companyId], references: [id], onDelete: Restrict)
  serviceRequest ServiceRequest @relation(fields: [serviceRequestId], references: [id])
  product        Product        @relation(fields: [productId], references: [id])
  consumedEvent  BusinessEvent? @relation("ServicePartConsumedEvent", fields: [consumedEventId], references: [id])

  @@unique([serviceRequestId, lineNo])
  @@index([companyId])
  @@index([serviceRequestId])
  @@index([productId])
  @@map("service_request_parts")
}

model ServiceEvent {
  id                String   @id @default(uuid())
  companyId         String   @map("company_id")
  serviceRequestId  String   @map("service_request_id")
  eventType         String   @map("event_type") // status_change/diagnosis/estimate/customer_approval/part_used/note/message/delivery
  eventData         String   @default("{}") @map("event_data")
  createdBy         String?  @map("created_by")
  createdAt         DateTime @default(now()) @map("created_at")

  company        Company        @relation(fields: [companyId], references: [id], onDelete: Restrict)
  serviceRequest ServiceRequest @relation(fields: [serviceRequestId], references: [id])
  creator        User?          @relation("ServiceEventCreatedBy", fields: [createdBy], references: [id])

  @@index([companyId])
  @@index([serviceRequestId])
  @@index([eventType])
  @@index([createdAt])
  @@map("service_events")
}

model WarrantyClaim {
  id                  String   @id @default(uuid())
  companyId           String   @map("company_id")
  serviceRequestId    String   @unique @map("service_request_id")
  claimType           String   @default("repair") @map("claim_type") // repair/replace/refund/supplier_claim
  status              String   @default("draft") // draft/submitted/approved/rejected/fulfilled/reversed
  eligibilityReason   String   @map("eligibility_reason")
  replacementSerialId String?  @unique @map("replacement_serial_id")
  supplierReference   String?  @map("supplier_reference")
  approvalRequestId   String?  @map("approval_request_id")
  approvedBy          String?  @map("approved_by")
  approvedAt          DateTime? @map("approved_at")
  fulfilledAt         DateTime? @map("fulfilled_at")

  company             Company        @relation(fields: [companyId], references: [id], onDelete: Restrict)
  serviceRequest      ServiceRequest @relation(fields: [serviceRequestId], references: [id])
  replacementSerial   ProductSerial? @relation(fields: [replacementSerialId], references: [id])
  approver            User?          @relation("WarrantyClaimApprovedBy", fields: [approvedBy], references: [id])

  @@index([companyId])
  @@index([claimType])
  @@index([status])
  @@map("warranty_claims")
}
// prisma/m6-additions.prisma
// M6 — §5.6A CRM + §5.13 Gift Cards/Coupons/Loyalty + §5.14 HR/Payroll

// ── CRM ──
model LeadSubject {
  id         String  @id @default(uuid())
  companyId  String  @map("company_id")
  name       String
  isActive   Boolean @default(true) @map("is_active")
  company    Company @relation(fields: [companyId], references: [id], onDelete: Restrict)
  leads      Lead[]
  @@unique([companyId, name])
  @@map("lead_subjects")
}

model LeadSource {
  id         String  @id @default(uuid())
  companyId  String  @map("company_id")
  name       String
  isActive   Boolean @default(true) @map("is_active")
  company    Company @relation(fields: [companyId], references: [id], onDelete: Restrict)
  leads      Lead[]
  @@unique([companyId, name])
  @@map("lead_sources")
}

model LeadStatus {
  id         String  @id @default(uuid())
  companyId  String  @map("company_id")
  name       String
  position   Int
  isWon      Boolean @default(false) @map("is_won")
  isLost     Boolean @default(false) @map("is_lost")
  isActive   Boolean @default(true) @map("is_active")
  company    Company @relation(fields: [companyId], references: [id], onDelete: Restrict)
  leads      Lead[]
  @@unique([companyId, name])
  @@unique([companyId, position])
  @@map("lead_statuses")
}

model Lead {
  id                  String   @id @default(uuid())
  companyId           String   @map("company_id")
  branchId            String?  @map("branch_id")
  subjectId           String?  @map("subject_id")
  sourceId            String?  @map("source_id")
  statusId            String   @map("status_id")
  assignedTo          String?  @map("assigned_to")
  name                String
  companyName         String?  @map("company_name")
  phone               String?
  email               String?
  estimatedValue      Decimal? @map("estimated_value")
  nextActionAt        DateTime? @map("next_action_at")
  notes               String?
  convertedCustomerId String?  @unique @map("converted_customer_id")
  convertedQuotationId String? @map("converted_quotation_id")
  lostReason          String?  @map("lost_reason")
  createdBy           String   @map("created_by")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @default(now()) @map("updated_at")

  company    Company       @relation(fields: [companyId], references: [id], onDelete: Restrict)
  branch     Branch?       @relation("LeadBranch", fields: [branchId], references: [id])
  subject    LeadSubject?  @relation(fields: [subjectId], references: [id])
  source     LeadSource?   @relation(fields: [sourceId], references: [id])
  status     LeadStatus    @relation(fields: [statusId], references: [id])
  assignee   User?         @relation("LeadAssignedTo", fields: [assignedTo], references: [id])
  convertedCustomer Customer? @relation(fields: [convertedCustomerId], references: [id])
  creator    User          @relation("LeadCreatedBy", fields: [createdBy], references: [id])
  activities LeadActivity[]

  @@index([companyId])
  @@index([statusId])
  @@index([assignedTo])
  @@index([nextActionAt])
  @@index([createdAt])
  @@map("leads")
}

model LeadActivity {
  id           String   @id @default(uuid())
  companyId    String   @map("company_id")
  leadId       String   @map("lead_id")
  activityType String   @map("activity_type")
  summary      String
  details      String?
  scheduledAt  DateTime? @map("scheduled_at")
  completedAt  DateTime? @map("completed_at")
  createdBy    String   @map("created_by")
  createdAt    DateTime @default(now()) @map("created_at")

  company Company @relation(fields: [companyId], references: [id], onDelete: Restrict)
  lead    Lead    @relation(fields: [leadId], references: [id])
  creator User    @relation("LeadActivityCreatedBy", fields: [createdBy], references: [id])

  @@index([companyId])
  @@index([leadId])
  @@index([activityType])
  @@index([scheduledAt])
  @@map("lead_activities")
}

// ── Gift Cards ──
model GiftCard {
  id           String   @id @default(uuid())
  companyId    String   @map("company_id")
  code         String   @unique
  pinHash      String?  @map("pin_hash")
  faceValue    Decimal  @map("face_value")
  status       String   @default("active") // active/redeemed/expired/lost_replaced
  issuedAt     DateTime @default(now()) @map("issued_at")
  expiresAt    DateTime? @map("expires_at")
  issuedBy     String   @map("issued_by")
  issuedSaleId String?  @map("issued_sale_id")

  company Company @relation(fields: [companyId], references: [id], onDelete: Restrict)
  issuer  User    @relation("GiftCardIssuedBy", fields: [issuedBy], references: [id])
  // Gap model backward relations
  transactions GiftCardTransaction[]

  @@index([companyId])
  @@index([status])
  @@map("gift_cards")
}

// ── HR ──
model Department {
  id                  String  @id @default(uuid())
  companyId           String  @map("company_id")
  name                String
  managerEmployeeId   String? @map("manager_employee_id")
  isActive            Boolean @default(true) @map("is_active")

  company Company @relation(fields: [companyId], references: [id], onDelete: Restrict)
  employees Employee[]
  @@unique([companyId, name])
  @@map("departments")
}

model Designation {
  id         String  @id @default(uuid())
  companyId  String  @map("company_id")
  name       String
  isActive   Boolean @default(true) @map("is_active")

  company Company @relation(fields: [companyId], references: [id], onDelete: Restrict)
  employees Employee[]
  @@unique([companyId, name])
  @@map("designations")
}

model Employee {
  id                       String   @id @default(uuid())
  companyId                String   @map("company_id")
  userId                   String?  @unique @map("user_id")
  employeeNo               String   @map("employee_no")
  branchId                 String   @map("branch_id")
  departmentId             String?  @map("department_id")
  designationId            String?  @map("designation_id")
  name                     String
  phone                    String?
  email                    String?
  address                  String?
  joinDate                 DateTime @map("join_date")
  employmentStatus         String   @default("active") @map("employment_status") // active/on_leave/terminated
  baseSalary               Decimal  @default(0) @map("base_salary")
  payrollExpenseAccountId  String   @map("payroll_expense_account_id")
  payrollPayableAccountId  String   @map("payroll_payable_account_id")
  bankAccountNo            String?  @map("bank_account_no")
  bankCode                 String?  @map("bank_code")
  bankBranchCode           String?  @map("bank_branch_code")
  terminatedAt             DateTime? @map("terminated_at")

  company      Company      @relation(fields: [companyId], references: [id], onDelete: Restrict)
  user         User?        @relation("EmployeeUser", fields: [userId], references: [id])
  branch       Branch       @relation("EmployeeBranch", fields: [branchId], references: [id])
  department   Department?  @relation(fields: [departmentId], references: [id])
  designation  Designation? @relation(fields: [designationId], references: [id])
  // Gap model backward relations
  leaveRequests    LeaveRequest[]
  attendanceRecords AttendanceRecord[]
  payrollItems     PayrollItem[]    @relation("PayrollItemEmployee")

  @@unique([companyId, employeeNo])
  @@index([companyId])
  @@index([branchId])
  @@index([employmentStatus])
  @@map("employees")
}

model PayrollRun {
  id              String   @id @default(uuid())
  companyId       String   @map("company_id")
  branchId        String?  @map("branch_id")
  referenceNo     String   @map("reference_no")
  periodStart     DateTime @map("period_start")
  periodEnd       DateTime @map("period_end")
  status          String   @default("draft") // draft/approved/posted/paid/reversed
  grossTotal      Decimal  @default(0) @map("gross_total")
  deductionTotal  Decimal  @default(0) @map("deduction_total")
  netTotal        Decimal  @default(0) @map("net_total")
  approvedBy      String?  @map("approved_by")
  postedAt        DateTime? @map("posted_at")
  createdBy       String   @map("created_by")
  createdAt       DateTime @default(now()) @map("created_at")

  company    Company @relation(fields: [companyId], references: [id], onDelete: Restrict)
  branch     Branch? @relation("PayrollRunBranch", fields: [branchId], references: [id])
  approver   User?   @relation("PayrollRunApprovedBy", fields: [approvedBy], references: [id])
  creator    User    @relation("PayrollRunCreatedBy", fields: [createdBy], references: [id])
  // Gap model backward relations
  payrollItems PayrollItem[]

  @@unique([companyId, referenceNo])
  @@index([companyId])
  @@index([status])
  @@map("payroll_runs")
}

// ── Notifications (already have CommunicationTemplate from M1) ──
model Notification {
  id              String   @id @default(uuid())
  companyId       String   @map("company_id")
  notificationType String  @map("notification_type")
  severity        String   @default("info") // info/warning/high/critical
  title           String
  body            String
  actionUrl       String?  @map("action_url")
  entityType      String?  @map("entity_type")
  entityId        String?  @map("entity_id")
  expiresAt       DateTime? @map("expires_at")
  createdAt       DateTime @default(now()) @map("created_at")

  company Company @relation(fields: [companyId], references: [id], onDelete: Restrict)
  // Gap model backward relations
  userNotifications UserNotification[]

  @@index([companyId])
  @@index([severity])
  @@index([createdAt])
  @@index([expiresAt])
  @@map("notifications")
}

// prisma/m7-additions.prisma
// M7 — §5.16 Integration, Outbox, Imports, and Offline

model OutboxEvent {
  id              String   @id @default(uuid())
  companyId       String   @map("company_id")
  businessEventId String   @map("business_event_id")
  eventName       String   @map("event_name")
  aggregateType   String   @map("aggregate_type")
  aggregateId     String   @map("aggregate_id")
  payload         String   @default("{}") // JSONB
  occurredAt      DateTime @default(now()) @map("occurred_at")
  publishedAt     DateTime? @map("published_at")
  attemptCount    Int      @default(0) @map("attempt_count")
  maxAttempts     Int      @default(10) @map("max_attempts")
  nextAttemptAt   DateTime @default(now()) @map("next_attempt_at")
  status          String   @default("pending") // pending/published/dead_letter/skipped
  deadLetteredAt  DateTime? @map("dead_lettered_at")
  deadLetterReason String? @map("dead_letter_reason")
  lastError       String?  @map("last_error")

  company Company @relation(fields: [companyId], references: [id], onDelete: Restrict)
  businessEvent BusinessEvent @relation("OutboxBusinessEvent", fields: [businessEventId], references: [id])
  webhookDeliveries WebhookDelivery[]

  @@index([companyId])
  @@index([status])
  @@index([nextAttemptAt])
  @@index([publishedAt])
  @@map("outbox_events")
}

model WebhookEndpoint {
  id              String   @id @default(uuid())
  companyId       String   @map("company_id")
  url             String
  secretCiphertext Bytes   @map("secret_ciphertext")
  subscribedEvents String  @default("[]") // JSONB array
  status          String   @default("active") // active/disabled
  createdBy       String   @map("created_by")
  createdAt       DateTime @default(now()) @map("created_at")

  company Company @relation(fields: [companyId], references: [id], onDelete: Restrict)
  deliveries WebhookDelivery[]

  @@unique([companyId, url])
  @@index([companyId])
  @@index([status])
  @@map("webhook_endpoints")
}

model WebhookDelivery {
  id              String   @id @default(uuid())
  companyId       String   @map("company_id")
  webhookEndpointId String  @map("webhook_endpoint_id")
  outboxEventId   String   @map("outbox_event_id")
  deliveryId      String   @unique
  signature       String
  timestampHeader String   @map("timestamp_header")
  status          String   @default("pending") // pending/delivered/failed/dead_letter
  attemptCount    Int      @default(0) @map("attempt_count")
  nextAttemptAt   DateTime @default(now()) @map("next_attempt_at")
  lastAttemptedAt DateTime? @map("last_attempted_at")
  responseStatus  Int?     @map("response_status")
  responseBodyExcerpt String? @map("response_body_excerpt")
  lastError       String?  @map("last_error")

  company Company @relation(fields: [companyId], references: [id], onDelete: Restrict)
  webhookEndpoint WebhookEndpoint @relation(fields: [webhookEndpointId], references: [id])
  outboxEvent OutboxEvent @relation(fields: [outboxEventId], references: [id])

  @@unique([webhookEndpointId, outboxEventId])
  @@index([companyId])
  @@index([status])
  @@index([nextAttemptAt])
  @@map("webhook_deliveries")
}

model ImportJob {
  id              String   @id @default(uuid())
  companyId       String   @map("company_id")
  jobType         String   @map("job_type") // product/customer/supplier/sale_draft/transfer_draft/purchase/opening_stock
  fileName        String   @map("file_name")
  objectKey       String?  @map("object_key") // S3 key for the uploaded file
  fileSha256      String?  @map("file_sha256") // CHAR(64) — checksum of source file
  status          String   @default("uploaded") // uploaded/validating/invalid/ready/importing/completed/partial/failed/cancelled
  totalRows       Int      @default(0) @map("total_rows")
  validRows       Int      @default(0) @map("valid_rows")
  invalidRows     Int      @default(0) @map("invalid_rows")
  committedRows   Int?     @map("committed_rows")
  resultObjectKey String?  @map("result_object_key") // S3 key for the error-row download
  dryRun          Boolean  @default(true) @map("dry_run")
  duplicateStrategy String? @map("duplicate_strategy") // skip/update/fail
  controlTotals   String?  @map("control_totals") // JSONB — expected vs actual row counts + amount sums
  errorSummary    String?  @map("error_summary")
  createdBy       String   @map("created_by")
  createdAt       DateTime @default(now()) @map("created_at")
  completedAt     DateTime? @map("completed_at")

  company Company @relation(fields: [companyId], references: [id], onDelete: Restrict)
  errors  ImportJobError[]

  @@index([companyId])
  @@index([status])
  @@index([fileSha256])
  @@map("import_jobs")
}

model ImportJobError {
  id              String   @id @default(uuid())
  companyId       String   @map("company_id")
  importJobId     String   @map("import_job_id")
  rowNumber       Int      @map("row_number")
  columnName      String?  @map("column_name")
  errorCode       String?  @map("error_code")
  errorValue      String?  @map("error_value")
  errorMessage    String   @map("error_message")
  rawRow          String?  @map("raw_row") // JSONB — original row data for error download

  company   Company   @relation(fields: [companyId], references: [id], onDelete: Restrict)
  importJob ImportJob @relation(fields: [importJobId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([importJobId])
  @@index([rowNumber])
  @@map("import_job_errors")
}

model OfflineCommand {
  id              String   @id @default(uuid())
  companyId       String   @map("company_id")
  deviceId        String   @map("device_id")
  commandType     String   @map("command_type") // cash_sale/held_sale_draft/shift_open/shift_close/customer_create/receipt_reprint
  sequenceNumber  Int      @map("sequence_number")
  payload         String   @default("{}") // JSONB — signed command data
  payloadHash     String   @map("payload_hash")
  idempotencyKey  String   @map("idempotency_key")
  status          String   @default("pending") // pending/synced/conflict/cancelled
  conflictReason  String?  @map("conflict_reason")
  syncedAt        DateTime? @map("synced_at")
  syncBatchId     String?  @map("sync_batch_id")
  createdAt       DateTime @default(now()) @map("created_at")

  company Company @relation(fields: [companyId], references: [id], onDelete: Restrict)

  @@unique([deviceId, sequenceNumber])
  @@index([companyId])
  @@index([deviceId])
  @@index([status])
  @@index([syncBatchId])
  @@map("offline_commands")
}

model OfflineSyncBatch {
  id              String   @id @default(uuid())
  companyId       String   @map("company_id")
  deviceId        String   @map("device_id")
  batchNumber     Int      @map("batch_number")
  commandCount    Int      @map("command_count")
