  errorSummary    String?  @map("error_summary")
  requestedBy     String   @map("requested_by")
  createdAt       DateTime @default(now()) @map("created_at")
  completedAt     DateTime? @map("completed_at")

  company   Company  @relation(fields: [companyId], references: [id], onDelete: Restrict)
  requester User     @relation("PrintJobRequestedBy", fields: [requestedBy], references: [id])

  @@index([companyId])
  @@index([status])
  @@index([entityType, entityId])
  @@map("print_jobs")
}

model StockBudgetLease {
  id              String   @id @default(uuid())
  companyId       String   @map("company_id")
  branchId        String   @map("branch_id")
  deviceId        String   @map("device_id")
  productId       String   @map("product_id")
  warehouseId     String   @map("warehouse_id")
  qtyGranted      Decimal  @map("qty_granted")
  qtyConsumed     Decimal  @default(0) @map("qty_consumed")
  expiresAt       DateTime @map("expires_at")
  status          String   @default("active") // active/exhausted/expired/revoked
  createdAt       DateTime @default(now()) @map("created_at")

  company    Company   @relation(fields: [companyId], references: [id], onDelete: Restrict)
  branch     Branch    @relation("StockBudgetBranch", fields: [branchId], references: [id])
  device     Device    @relation("StockBudgetDevice", fields: [deviceId], references: [id])
  product    Product   @relation("StockBudgetProduct", fields: [productId], references: [id])
  warehouse  Warehouse @relation("StockBudgetWarehouse", fields: [warehouseId], references: [id])

  @@index([companyId])
  @@index([deviceId])
  @@index([productId])
  @@index([status])
  @@index([expiresAt])
  @@map("stock_budget_leases")
}

model RiskAssessment {
  id              String   @id @default(uuid())
  companyId       String   @map("company_id")
  providerCode    String   @map("provider_code")
  subjectType     String   @map("subject_type") // customer/lead/sale/delivery
  subjectId       String   @map("subject_id")
  requestEventId  String   @map("request_event_id")
  score           Decimal? 
  decision        String   @default("allow") // allow/review/block/unavailable
  reasonCodes     String   @default("[]") // JSONB array
  providerReference String? @map("provider_reference")
  sanitizedResponse String @default("{}") @map("sanitized_response")
  assessedAt      DateTime @default(now()) @map("assessed_at")
  expiresAt       DateTime @map("expires_at")

  company       Company       @relation(fields: [companyId], references: [id], onDelete: Restrict)
  requestEvent  BusinessEvent @relation("RiskAssessmentEvent", fields: [requestEventId], references: [id])
  outcomes      RiskAssessmentOutcome[]

  @@unique([companyId, requestEventId, providerCode])
  @@index([companyId])
  @@index([subjectType, subjectId])
  @@index([decision])
  @@index([expiresAt])
  @@map("risk_assessments")
}

// Backward relation for RiskAssessmentOutcome (defined in m-gap-additions.prisma)

// ── §20.D09 Privacy tables ──

model DataSubjectRequest {
  id              String   @id @default(uuid())
  companyId       String   @map("company_id")
  requestType     String   @map("request_type") // access/rectification/erasure/portability/objection
  customerId      String?  @map("customer_id")
  supplierId      String?  @map("supplier_id")
  status          String   @default("open") // open/in_progress/completed/rejected
  details         String?
  resolvedBy      String?  @map("resolved_by")
  resolvedAt      DateTime? @map("resolved_at")
  createdAt       DateTime @default(now()) @map("created_at")

  company   Company   @relation(fields: [companyId], references: [id], onDelete: Restrict)
  customer  Customer? @relation("DSRCustomer", fields: [customerId], references: [id])

  @@index([companyId])
  @@index([requestType])
  @@index([status])
  @@map("data_subject_requests")
}

model LegalHold {
  id              String   @id @default(uuid())
  companyId       String   @map("company_id")
  entityType      String   @map("entity_type")
  entityId        String   @map("entity_id")
  reason          String
  declaredBy      String   @map("declared_by")
  declaredAt      DateTime @default(now()) @map("declared_at")
  releasedAt      DateTime? @map("released_at")

  company   Company @relation(fields: [companyId], references: [id], onDelete: Restrict)
  declarer  User    @relation("LegalHoldDeclaredBy", fields: [declaredBy], references: [id])

  @@index([companyId])
  @@index([entityType, entityId])
  @@index([releasedAt])
  @@map("legal_holds")
}

// ── Risk Assessment Outcomes (for tuning thresholds) ──
// Records the actual outcome of a transaction that was risk-assessed,
// so admins can measure false-positive (review/block → no issue) and
// false-negative (allow → chargeback/return/fraud) rates per threshold.

model RiskAssessmentOutcome {
  id                  String   @id @default(uuid())
  companyId           String   @map("company_id")
  riskAssessmentId    String   @map("risk_assessment_id")
  outcomeType         String   @map("outcome_type") // completed/returned/charged_back/refunded/fraud_confirmed/no_issue
  outcomeNotes        String?  @map("outcome_notes")
  outcomeAmount       Decimal? @map("outcome_amount")
  recordedBy          String?  @map("recorded_by") // user ID or "system"
  recordedAt          DateTime @default(now()) @map("recorded_at")

  company           Company         @relation(fields: [companyId], references: [id], onDelete: Restrict)
  riskAssessment    RiskAssessment  @relation(fields: [riskAssessmentId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([riskAssessmentId])
  @@index([outcomeType])
  @@index([recordedAt])
  @@map("risk_assessment_outcomes")
}

// ── Risk Threshold Change History (for tuning audit) ──
// Records every change to a RISK_* env var with before/after values + reason.
// Enables correlation between tuning actions and FP/FN report changes.

model RiskThresholdChange {
  id          String   @id @default(uuid())
  companyId   String?  @map("company_id") // null = global change
  thresholdKey String  @map("threshold_key") // e.g. CUSTOMER_DEBT_THRESHOLD
  oldValue    String?  @map("old_value")
  newValue    String   @map("new_value")
  reason      String?
  changedBy   String   @map("changed_by") // user ID or "system"
  changedAt   DateTime @default(now()) @map("changed_at")

  @@index([companyId])
  @@index([thresholdKey])
  @@index([changedAt])
  @@map("risk_threshold_changes")
}

// ── Currency Revaluation (§20.D12) ──
// Records each period-end revaluation of open foreign-currency balances.
// Unrealized gain/loss posted to exchange_gain_loss_account_id.
// Reversed at start of next period to avoid double-counting.

model CurrencyRevaluation {
  id                     String   @id @default(uuid())
  companyId              String   @map("company_id")
  revaluationDate        DateTime @map("revaluation_date")
  journalEntryId         String?  @map("journal_entry_id")
  reversalJournalEntryId String?  @map("reversal_journal_entry_id")
  reversalOfId           String?  @map("reversal_of_id")
  totalUnrealizedGain    Decimal  @default(0) @map("total_unrealized_gain")
  totalUnrealizedLoss    Decimal  @default(0) @map("total_unrealized_loss")
  periodEndRate          Decimal  @map("period_end_rate")
  currencyCode           String   @map("currency_code")
  createdBy              String   @map("created_by")
  createdAt              DateTime @default(now()) @map("created_at")
  reversedAt             DateTime? @map("reversed_at")

  company Company @relation(fields: [companyId], references: [id], onDelete: Restrict)

  @@index([companyId])
  @@index([revaluationDate])
  @@index([currencyCode])
  @@map("currency_revaluations")
}

// ──────────────────────────────────────────────────────────────────────
// Fixed Asset Management (AM-BR)
// ──────────────────────────────────────────────────────────────────────

model FixedAsset {
  id                    String   @id @default(uuid())
  companyId             String   @map("company_id")
  assetCode             String   @map("asset_code")
  name                  String
  description           String?
  categoryId            String?  @map("category_id")
  branchId              String?  @map("branch_id")
  location              String?
  serialNumber          String?  @map("serial_number")
  purchaseDate          DateTime @map("purchase_date")
  purchaseCost          Decimal  @map("purchase_cost")
  salvageValue          Decimal  @default(0) @map("salvage_value")
  usefulLifeMonths      Int      @map("useful_life_months")
  depreciationMethod    String   @default("straight_line") @map("depreciation_method")
  depreciationRate      Decimal? @default(0) @map("depreciation_rate")
  accumulatedDepreciation Decimal @default(0) @map("accumulated_depreciation")
  netBookValue          Decimal  @map("net_book_value")
  status                String   @default("active")
  assetAccountId        String   @map("asset_account_id")
  accumDepAccountId     String   @map("accum_dep_account_id")
  depExpenseAccountId   String   @map("dep_expense_account_id")
  gainLossAccountId     String?  @map("gain_loss_account_id")
  disposedAt            DateTime? @map("disposed_at")
  disposalAmount        Decimal? @map("disposal_amount")
  disposalMethod        String?  @map("disposal_method")
  createdBy             String   @map("created_by")
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @default(now()) @map("updated_at")

  company               Company  @relation(fields: [companyId], references: [id], onDelete: Restrict)
  category              FixedAssetCategory? @relation(fields: [categoryId], references: [id])
  branch                Branch?  @relation(fields: [branchId], references: [id])
  depreciationRuns      FixedAssetDepreciation[]

  @@unique([companyId, assetCode])
  @@index([companyId])
  @@index([status])
  @@map("fixed_assets")
}

model FixedAssetCategory {
  id              String   @id @default(uuid())
  companyId       String   @map("company_id")
  name            String
  code            String
  defaultLifeMonths Int    @map("default_life_months")
  defaultMethod   String   @default("straight_line") @map("default_method")
  assetAccountId  String   @map("asset_account_id")
  accumDepAccountId String @map("accum_dep_account_id")
  depExpenseAccountId String @map("dep_expense_account_id")
  isActive        Boolean  @default(true) @map("is_active")

  company         Company  @relation(fields: [companyId], references: [id], onDelete: Restrict)
  assets          FixedAsset[]

  @@unique([companyId, code])
  @@index([companyId])
  @@map("fixed_asset_categories")
}

model FixedAssetDepreciation {
  id              String   @id @default(uuid())
  companyId       String   @map("company_id")
  fixedAssetId    String   @map("fixed_asset_id")
  periodStart     DateTime @map("period_start")
  periodEnd       DateTime @map("period_end")
  depreciationAmount Decimal @map("depreciation_amount")
  accumulatedAfter Decimal @map("accumulated_after")
  netBookValueAfter Decimal @map("net_book_value_after")
  journalEntryId  String?  @map("journal_entry_id")
  eventId         String   @map("event_id")
  postedAt        DateTime @default(now()) @map("posted_at")
  postedBy        String   @map("posted_by")

  company         Company   @relation(fields: [companyId], references: [id], onDelete: Restrict)
  fixedAsset      FixedAsset @relation(fields: [fixedAssetId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([fixedAssetId])
  @@index([periodEnd])
  @@map("fixed_asset_depreciation")
}

// ──────────────────────────────────────────────────────────────────────
// Banking Reconciliation (AM-BR)
// ──────────────────────────────────────────────────────────────────────

model BankReconciliation {
  id              String   @id @default(uuid())
  companyId       String   @map("company_id")
  financialAccountId String @map("financial_account_id")
  statementDate   DateTime @map("statement_date")
  statementOpeningBalance Decimal @map("statement_opening_balance")
  statementClosingBalance Decimal @map("statement_closing_balance")
  systemOpeningBalance Decimal @map("system_opening_balance")
  systemClosingBalance Decimal @map("system_closing_balance")
  status          String   @default("draft")
  matchedTransactions Int  @default(0) @map("matched_transactions")
  unmatchedSystem Int      @default(0) @map("unmatched_system")
  unmatchedStatement Int   @default(0) @map("unmatched_statement")
  variance        Decimal  @default(0)
  journalEntryId  String?  @map("journal_entry_id")
  reconciledBy    String?  @map("reconciled_by")
  reconciledAt    DateTime? @map("reconciled_at")
  createdBy       String   @map("created_by")
  createdAt       DateTime @default(now()) @map("created_at")

  company         Company  @relation(fields: [companyId], references: [id], onDelete: Restrict)
  financialAccount FinancialAccount @relation(fields: [financialAccountId], references: [id])
  lines           BankReconciliationLine[]

  @@index([companyId])
  @@index([financialAccountId])
  @@index([status])
  @@map("bank_reconciliations")
}

model BankReconciliationLine {
  id              String   @id @default(uuid())
  companyId       String   @map("company_id")
  reconciliationId String  @map("reconciliation_id")
  lineType        String   @map("line_type")
  transactionDate DateTime @map("transaction_date")
  description     String
  amount          Decimal
  referenceNo     String?  @map("reference_no")
  paymentId       String?  @map("payment_id")
  matchedLineId   String?  @map("matched_line_id")
  matchStatus     String   @default("unmatched") @map("match_status")
  matchMethod     String?  @map("match_method")
  matchedBy       String?  @map("matched_by")
  matchedAt       DateTime? @map("matched_at")

  company         Company  @relation(fields: [companyId], references: [id], onDelete: Restrict)
  reconciliation  BankReconciliation @relation(fields: [reconciliationId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([reconciliationId])
  @@index([matchStatus])
  @@map("bank_reconciliation_lines")
}
