model account_transfers {
  id                                                                                 String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  company_id                                                                         String              @db.Uuid
  branch_id                                                                          String              @db.Uuid
  reference_no                                                                       String              @db.VarChar
  client_txn_id                                                                      String              @db.Uuid
  from_financial_account_id                                                          String              @db.Uuid
  to_financial_account_id                                                            String              @db.Uuid
  from_currency_code                                                                 String              @db.Char(3)
  to_currency_code                                                                   String              @db.Char(3)
  from_amount                                                                        Decimal             @db.Decimal(18, 2)
  to_amount                                                                          Decimal             @db.Decimal(18, 2)
  exchange_rate                                                                      Decimal             @default(1) @db.Decimal(18, 6)
  transfer_fee                                                                       Decimal             @default(0) @db.Decimal(18, 2)
  status                                                                             String              @default("draft") @db.VarChar
  business_date                                                                      DateTime            @db.Timestamptz(6)
  journal_entry_id                                                                   String?             @db.Uuid
  approval_request_id                                                                String?             @db.Uuid
  reversal_of_id                                                                     String?             @db.Uuid
  notes                                                                              String?             @db.VarChar
  created_by                                                                         String              @db.Uuid
  approved_by                                                                        String?             @db.Uuid
  posted_at                                                                          DateTime?           @db.Timestamptz(6)
  users_account_transfers_approved_byTousers                                         users?              @relation("account_transfers_approved_byTousers", fields: [approved_by], references: [id], onDelete: Restrict, onUpdate: NoAction, map: "fk_account_transfers_approved_by")
  branches                                                                           branches            @relation(fields: [branch_id], references: [id], onUpdate: NoAction, map: "fk_account_transfers_branch_id")
  companies                                                                          companies           @relation(fields: [company_id], references: [id], onUpdate: NoAction, map: "fk_account_transfers_company_id")
  users_account_transfers_created_byTousers                                          users               @relation("account_transfers_created_byTousers", fields: [created_by], references: [id], onUpdate: NoAction, map: "fk_account_transfers_created_by")
  currencies_account_transfers_from_currency_codeTocurrencies                        currencies          @relation("account_transfers_from_currency_codeTocurrencies", fields: [from_currency_code], references: [code], onUpdate: NoAction, map: "fk_account_transfers_from_currency_code")
  financial_accounts_account_transfers_from_financial_account_idTofinancial_accounts financial_accounts  @relation("account_transfers_from_financial_account_idTofinancial_accounts", fields: [from_financial_account_id], references: [id], onUpdate: NoAction, map: "fk_account_transfers_from_financial_account_id")
  account_transfers                                                                  account_transfers?  @relation("account_transfersToaccount_transfers", fields: [reversal_of_id], references: [id], onDelete: Restrict, onUpdate: NoAction, map: "fk_account_transfers_reversal_of_id")
  other_account_transfers                                                            account_transfers[] @relation("account_transfersToaccount_transfers")
  currencies_account_transfers_to_currency_codeTocurrencies                          currencies          @relation("account_transfers_to_currency_codeTocurrencies", fields: [to_currency_code], references: [code], onUpdate: NoAction, map: "fk_account_transfers_to_currency_code")
  financial_accounts_account_transfers_to_financial_account_idTofinancial_accounts   financial_accounts  @relation("account_transfers_to_financial_account_idTofinancial_accounts", fields: [to_financial_account_id], references: [id], onUpdate: NoAction, map: "fk_account_transfers_to_financial_account_id")

  @@unique([company_id, client_txn_id], map: "uq_account_transfers_company_id_client_txn_id")
  @@unique([company_id, reference_no], map: "uq_account_transfers_company_id_reference_no")
  @@index([business_date], map: "idx_account_transfers_business_date")
  @@index([company_id], map: "idx_account_transfers_company_id")
  @@index([status], map: "idx_account_transfers_status")
}

